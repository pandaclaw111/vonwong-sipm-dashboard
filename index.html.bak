// Load cases.json and merge with inline 2026 cases
let casesDataLoaded = false;
function loadCasesData() {
  fetch('cases.json')
    .then(response => {
      if (!response.ok) throw new Error('Failed to load cases.json');
      return response.json();
    })
    .then(jsonCases => {
      // jsonCases has ids 1-100 with full real data from cases.json
      // Merge with inline 2026 cases (101+)
      CASES.length = 0;
      CASES.push(...jsonCases, ...INLINE_CASES_2026);
      ALL_CASES = [...CASES];
      casesDataLoaded = true;
      console.log('✅ Cases data loaded:', CASES.length, 'total cases');
      
      // Initialize filteredCases and sort
      filteredCases = [...ALL_CASES];
      sortCases();
      
      // Re-render after data loads
      renderStats();
      renderCases();
      updateBadgeCount();
      
      // Re-render sections that depend on cases data
      setTimeout(() => {
        renderIntelligenceBriefing();
        renderStillActiveCases();
      }, 100);
    })
    .catch(err => {
      console.warn('⚠️ Could not load cases.json, using inline data only:', err.message);
      // Fallback: use just the inline 2026 cases
      CASES.length = 0;
      CASES.push(...INLINE_CASES_2026);
      ALL_CASES = [...CASES];
      filteredCases = [...ALL_CASES];
      casesDataLoaded = true;
      sortCases();
      renderStats();
      renderCases();
    });
}

function updateBadgeCount() {
  const badge = document.querySelector('.badge-count');
  if (badge) badge.textContent = ALL_CASES.length + ' Cases';
}



