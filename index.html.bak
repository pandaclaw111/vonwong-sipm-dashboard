</footer>
<script>
// ===== ENRICHED DATA (loaded from external JSON) =====
let ENRICHED_DATA = {};
let ECOSYSTEM_DATA = {};
let enrichedDataLoaded = false;
let ecosystemDataLoaded = false;

// Fetch enriched.json at startup
fetch('enriched.json')
  .then(response => {
    if (!response.ok) throw new Error('Failed to load enriched.json');
    return response.json();
  })
  .then(data => {
    ENRICHED_DATA = data;
    enrichedDataLoaded = true;
    console.log('✅ Enriched data loaded:', Object.keys(ENRICHED_DATA).length, 'entries');
  })
  .catch(err => {
    console.warn('⚠️ Could not load enriched.json:', err.message);
    enrichedDataLoaded = false;
  });

// Fetch ecosystem.json at startup
fetch('ecosystem.json')
  .then(response => {
    if (!response.ok) throw new Error('Failed to load ecosystem.json');
    return response.json();
  })
  .then(data => {
    ECOSYSTEM_DATA = data;
    ecosystemDataLoaded = true;
    console.log('✅ Ecosystem data loaded');
    // Re-render ecosystem after data loads
    setTimeout(renderEcosystem, 100);
  })
  .catch(err => {
    console.warn('⚠️ Could not load ecosystem.json:', err.message);
    ecosystemDataLoaded = false;
  });

// Helper to find enriched data by case ID or name (with fuzzy matching)
function getEnrichedData(idOrName) {
  if (!enrichedDataLoaded || !ENRICHED_DATA) return null;
  // Try by ID first
  if (typeof idOrName === 'number' || /^\d+$/.test(idOrName)) {
    const byId = ENRICHED_DATA[String(idOrName)];
    if (byId) return byId;
  }
  // Try by exact name match
  const name = String(idOrName).toLowerCase().trim();
  for (const key of Object.keys(ENRICHED_DATA)) {
    const entry = ENRICHED_DATA[key];
    if (entry && entry.name && entry.name.toLowerCase() === name) {
      return entry;
    }
  }
  // Try by partial name match (contains)
  for (const key of Object.keys(ENRICHED_DATA)) {
    const entry = ENRICHED_DATA[key];
    if (entry && entry.name && entry.name.toLowerCase().includes(name)) {
      return entry;
    }
  }
  // Try reverse partial match (query contains entry name)
  for (const key of Object.keys(ENRICHED_DATA)) {
    const entry = ENRICHED_DATA[key];
    if (entry && entry.name && name.includes(entry.name.toLowerCase())) {
      return entry;
    }
  }
  // Try by key words match (split and match major words)
  const words = name.split(/[\s\-\/]+/).filter(w => w.length > 3);
  for (const key of Object.keys(ENRICHED_DATA)) {
    const entry = ENRICHED_DATA[key];
    if (entry && entry.name) {
      const entryWords = entry.name.toLowerCase().split(/[\s\-\/]+/);
      const matchCount = words.filter(w => entryWords.some(ew => ew.includes(w) || w.includes(ew))).length;
      if (matchCount >= 2 || (words.length === 1 && matchCount === 1)) {
        return entry;
      }
    }
  }
  return null;
}

// Find case by name (for linking movements)
function findCaseByName(name) {
  if (!name || !ALL_CASES.length) return null;
  const searchName = name.toLowerCase().trim();
  // Exact match
  let found = ALL_CASES.find(c => c.name.toLowerCase() === searchName);
  if (found) return found;
  // Partial match
  found = ALL_CASES.find(c => c.name.toLowerCase().includes(searchName) || searchName.includes(c.name.toLowerCase()));
  if (found) return found;
  // Word match
  const words = searchName.split(/[\s\-\/]+/).filter(w => w.length > 3);
  for (const c of ALL_CASES) {
    const caseWords = c.name.toLowerCase().split(/[\s\-\/]+/);
    const matchCount = words.filter(w => caseWords.some(cw => cw.includes(w) || w.includes(cw))).length;
    if (matchCount >= 2) return c;
  }
  return null;
}

// Create clickable movement link HTML
function createMovementLink(movementName, displayName) {
  const caseData = findCaseByName(movementName);
  if (caseData) {
    return `<span class="movement-link" onclick="openCaseModal(${caseData.id})">${displayName || movementName}</span>`;
  }
  // If no case found, just return plain text
  return displayName || movementName;
}

// ===== NCRS SCORING SYSTEM =====
// Convert dimension values to numeric scores (1-10)
// Now primarily handles numeric values directly, with legacy string fallback
function getDimensionScore(value) {
  // If already numeric, return it directly (clamped to 1-10)
  if (typeof value === 'number') {
    return Math.min(10, Math.max(1, Math.round(value)));
  }
  // Legacy string fallback for old data format
  const valueStr = String(value).toLowerCase();
  const legacyMap = {
    'low': 5, 'medium': 5, 'high': 5,
    'weak': 5, 'moderate': 5, 'strong': 5
  };
  return legacyMap[valueStr] || 5;
}

// Calculate total NCRS score (out of 60) and percentage
// Each movement scored across 6 dimensions (1-10 each, max 60 total)
function calculateNCRSScore(ncrs) {
  if (!ncrs) return { total: 0, percentage: 0, dimensions: {} };
  
  const dims = ['tipping_threshold', 'conformity_trap_risk', 'benefit_visibility', 
                'penalty_reduction', 'broad_angle_potential', 'leader_persistence'];
  const dimensions = {};
  let total = 0;
  
  for (const dim of dims) {
    const val = getDimensionScore(ncrs[dim]);
    dimensions[dim] = val;
    total += val;
  }
  
  // Use overall_readiness if it's the sum (>10), otherwise use calculated total
  if (ncrs.overall_readiness && ncrs.overall_readiness > 10) {
    total = ncrs.overall_readiness; // It's already the sum
  }
  
  return { 
    total, 
    percentage: Math.round((total / 60) * 100), 
    dimensions 
  };
}

// Get percentage class for styling
function getPercentageClass(percentage) {
  if (percentage >= 80) return 'high';
  if (percentage >= 50) return 'medium';
  return 'low';
}

// Render enriched timeline
function renderEnrichedTimeline(progressMarkers) {
  if (!progressMarkers || progressMarkers.length === 0) return '';
  return `<div class="modal-section">
    <div class="modal-section-title">📅 Timeline</div>
    <div class="enriched-timeline">
      ${progressMarkers.map(m => `
        <div class="enriched-timeline-item type-${m.type}">
          <span class="enriched-timeline-year">${m.year}</span>
          <span class="enriched-timeline-type ${m.type}">${m.type}</span>
          <div class="enriched-timeline-event">${m.event}</div>
        </div>
      `).join('')}
    </div>
  </div>`;
}

// Render enriched ecosystem players
function renderEnrichedEcosystem(keyActors) {
  if (!keyActors) return '';
  let html = '<div class="modal-section"><div class="modal-section-title">👥 Ecosystem Players</div><div class="enriched-ecosystem">';
  
  // Lead organizations
  if (keyActors.lead_orgs && keyActors.lead_orgs.length > 0) {
    html += `<div class="enriched-ecosystem-section">
      <div class="enriched-ecosystem-title">🏛️ Lead Organizations</div>
      ${keyActors.lead_orgs.map(org => `
        <div class="enriched-org-item">
          <div class="enriched-org-name">${org.name}</div>
          ${org.description ? `<div class="enriched-org-desc">${org.description}</div>` : ''}
        </div>
      `).join('')}
    </div>`;
  }
  
  // Funders
  if (keyActors.funders && keyActors.funders.length > 0) {
    html += `<div class="enriched-ecosystem-section">
      <div class="enriched-ecosystem-title">💰 Funders</div>
      <div class="enriched-actor-list">${keyActors.funders.map(f => {
        const name = typeof f === 'object' ? f.name : f;
        const verified = typeof f === 'object' ? f.verified : null;
        const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
        return `<span class="enriched-actor-tag" onclick="openFunderModal('${name}')" style="cursor:pointer;">${name}${badge}</span>`;
      }).join('')}</div>
    </div>`;
  }
  
  // Celebrities/Influencers
  if (keyActors.celebrities && keyActors.celebrities.length > 0) {
    html += `<div class="enriched-ecosystem-section">
      <div class="enriched-ecosystem-title">⭐ Celebrities & Influencers</div>
      <div class="enriched-actor-list">${keyActors.celebrities.map(c => {
        const name = typeof c === 'object' ? c.name : c;
        const verified = typeof c === 'object' ? c.verified : null;
        const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
        return `<span class="enriched-actor-tag">${name}${badge}</span>`;
      }).join('')}</div>
    </div>`;
  }
  
  // Government champions
  if (keyActors.government_champions && keyActors.government_champions.length > 0) {
    html += `<div class="enriched-ecosystem-section">
      <div class="enriched-ecosystem-title">🏛️ Government Champions</div>
      <div class="enriched-actor-list">${keyActors.government_champions.map(g => {
        const name = typeof g === 'object' ? g.name : g;
        const verified = typeof g === 'object' ? g.verified : null;
        const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
        return `<span class="enriched-actor-tag">${name}${badge}</span>`;
      }).join('')}</div>
    </div>`;
  }
  
  // Corporate actors
  if (keyActors.corporate_actors) {
    if (keyActors.corporate_actors.villains && keyActors.corporate_actors.villains.length > 0) {
      html += `<div class="enriched-ecosystem-section">
        <div class="enriched-ecosystem-title">🚫 Corporate Villains</div>
        <div class="enriched-actor-list">${keyActors.corporate_actors.villains.map(v => {
          const name = typeof v === 'object' ? v.name : v;
          const verified = typeof v === 'object' ? v.verified : null;
          const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
          return `<span class="enriched-actor-tag villain">${name}${badge}</span>`;
        }).join('')}</div>
      </div>`;
    }
    if (keyActors.corporate_actors.allies && keyActors.corporate_actors.allies.length > 0) {
      html += `<div class="enriched-ecosystem-section">
        <div class="enriched-ecosystem-title">✅ Corporate Allies</div>
        <div class="enriched-actor-list">${keyActors.corporate_actors.allies.map(a => {
          const name = typeof a === 'object' ? a.name : a;
          const verified = typeof a === 'object' ? a.verified : null;
          const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
          return `<span class="enriched-actor-tag ally">${name}${badge}</span>`;
        }).join('')}</div>
      </div>`;
    }
  }
  
  // International bodies
  if (keyActors.international && keyActors.international.length > 0) {
    html += `<div class="enriched-ecosystem-section">
      <div class="enriched-ecosystem-title">🌍 International Bodies</div>
      <div class="enriched-actor-list">${keyActors.international.map(i => {
        const name = typeof i === 'object' ? i.name : i;
        const verified = typeof i === 'object' ? i.verified : null;
        const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
        return `<span class="enriched-actor-tag">${name}${badge}</span>`;
      }).join('')}</div>
    </div>`;
  }
  
  html += '</div></div>';
  return html;
}

// Render enriched cultural markers
function renderEnrichedCultural(culturalMarkers) {
  if (!culturalMarkers) return '';
  let html = '<div class="modal-section"><div class="modal-section-title">📣 Cultural Markers</div><div class="enriched-cultural">';
  
  if (culturalMarkers.hashtags && culturalMarkers.hashtags.length > 0) {
    html += `<div class="enriched-cultural-group">
      <div class="enriched-cultural-label">Hashtags</div>
      <div>${culturalMarkers.hashtags.map(h => `<span class="enriched-hashtag">${h}</span>`).join('')}</div>
    </div>`;
  }
  
  if (culturalMarkers.slogans && culturalMarkers.slogans.length > 0) {
    html += `<div class="enriched-cultural-group">
      <div class="enriched-cultural-label">Slogans</div>
      <div>${culturalMarkers.slogans.map(s => `<span class="enriched-slogan">${s}</span>`).join('')}</div>
    </div>`;
  }
  
  if (culturalMarkers.symbols && culturalMarkers.symbols.length > 0) {
    html += `<div class="enriched-cultural-group">
      <div class="enriched-cultural-label">Symbols</div>
      <div>${culturalMarkers.symbols.map(s => `<span class="enriched-symbol">${s}</span>`).join('')}</div>
    </div>`;
  }
  
  if (culturalMarkers.viral_moments && culturalMarkers.viral_moments.length > 0) {
    html += `<div class="enriched-cultural-group">
      <div class="enriched-cultural-label">Viral Moments</div>
      <div>${culturalMarkers.viral_moments.map(v => `<div class="enriched-viral">📱 ${v}</div>`).join('')}</div>
    </div>`;
  }
  
  if (culturalMarkers.key_media && culturalMarkers.key_media.length > 0) {
    html += `<div class="enriched-cultural-group">
      <div class="enriched-cultural-label">Key Media</div>
      <div>${culturalMarkers.key_media.map(m => `<div class="enriched-viral">🎬 ${m}</div>`).join('')}</div>
    </div>`;
  }
  
  html += '</div></div>';
  return html;
}

// Render enriched sources
function renderEnrichedSources(sources) {
  if (!sources || sources.length === 0) return '';
  return `<div class="modal-section">
    <div class="modal-section-title">📚 Sources</div>
    <div class="enriched-sources">
      ${sources.map(s => `
        <div class="enriched-source-item">
          <a href="${s.url}" target="_blank" class="enriched-source-link">${s.title}</a>
          <span class="enriched-source-type">${s.type || 'link'}</span>
        </div>
      `).join('')}
    </div>
  </div>`;
}

// Render cross-movement links
function renderEnrichedCrossLinks(crossLinks) {
  if (!crossLinks || crossLinks.length === 0) return '';
  return `<div class="modal-section">
    <div class="modal-section-title">🔗 Connected Movements</div>
    <div class="enriched-cross-links">
      ${crossLinks.map(link => `
        <div class="enriched-cross-link" onclick="openCaseModal(${link.id})">
          <div class="enriched-cross-link-name">${link.name}</div>
          <div class="enriched-cross-link-rel">${link.relationship}</div>
        </div>
      `).join('')}
    </div>
  </div>`;
}

// Render what actually changed
function renderEnrichedChange(changeText) {
  if (!changeText) return '';
  return `<div class="enriched-change-summary">
    <div class="enriched-change-title">🎯 What Actually Changed</div>
    <div class="enriched-change-text">${changeText}</div>
  </div>`;
}

// Render NCRS dimension breakdown
function renderNCRSBreakdown(ncrsScore) {
  const dims = ncrsScore.dimensions;
  const dimensionMeta = {
    tipping_threshold: { name: 'Tipping Threshold', color: '#ff6b6b' },
    conformity_trap_risk: { name: 'Conformity Trap Risk', color: '#ffd93d' },
    benefit_visibility: { name: 'Benefit Visibility', color: '#00d4aa' },
    penalty_reduction: { name: 'Penalty Reduction', color: '#4a9eff' },
    broad_angle_potential: { name: 'Broad Angle Potential', color: '#a29bfe' },
    leader_persistence: { name: 'Leader Persistence', color: '#fd9644' }
  };
  
  return `<div class="ncrs-breakdown">
    <div class="ncrs-breakdown-title">📊 NCRS Dimension Breakdown (${ncrsScore.total}/60 = ${ncrsScore.percentage}%)</div>
    ${Object.entries(dims).map(([key, val]) => {
      const meta = dimensionMeta[key] || { name: key, color: '#6b7394' };
      return `<div class="ncrs-dimension-row">
        <div class="ncrs-dimension-name">${meta.name}</div>
        <div class="ncrs-dimension-bar">
          <div class="ncrs-dimension-fill" style="width:${val * 10}%;background:${meta.color};"></div>
        </div>
        <div class="ncrs-dimension-score" style="color:${meta.color};">${val}</div>
      </div>`;
    }).join('')}
  </div>`;
}

