// ===== HELPER FUNCTIONS =====
function getRegionGroup(r){const x=(r||'').toLowerCase();if(x.includes('global'))return'Global';if(['nigeria','kenya','sudan','africa'].some(y=>x.includes(y)))return'Africa/MENA';if(['india','hong kong','asia','pacific'].some(y=>x.includes(y)))return'Asia/Pacific';if(['chile','brazil','united states','america'].some(y=>x.includes(y)))return'Americas';if(['uk','france','europe'].some(y=>x.includes(y)))return'Europe';return'Global';}
let filteredCases=[],currentSort='score',currentPage=1;const PAGE_SIZE=20;
function scoreColor(p){return p>=80?'#ff6b6b':p>=50?'#ffd93d':'#00d4aa';}
function outcomeLabel(n){return['Suppressed','Awareness Only','Partial Win','Cultural Shift','Major Win','Full Change'][n]||'Unknown';}
function getPastMovementBadge(c) {
  // Use outcome_score from enriched data (0-5 scale)
  // 5 = complete norm change, 0 = failed
  // Also check last progress_marker type for REVERSAL/ONGOING
  const enriched = ENRICHED_DATA && ENRICHED_DATA[String(c.id)];
  const outcomeScore = enriched ? enriched.outcome_score : null;
  const markers = enriched ? (enriched.progress_markers || []) : [];
  const lastMarker = markers[markers.length - 1];
  const lastType = lastMarker ? lastMarker.type : null;
  const failed = c.failed;

  if (failed) return '<span class="deploy-badge dormant">❌ FAILED</span>';
  if (outcomeScore === 5) return '<span class="deploy-badge resolved">✅ NORM CHANGED</span>';
  if (lastType === 'REVERSAL') return '<span class="deploy-badge reversal">⚠️ UNDER THREAT</span>';
  if (lastType === 'ONGOING' || outcomeScore >= 3) return '<span class="deploy-badge still-active">⚡ ONGOING</span>';
  if (outcomeScore >= 2) return '<span class="deploy-badge watch">👁️ PARTIAL WIN</span>';
  return '<span class="deploy-badge prepare">🎯 IN PROGRESS</span>';
}

function getDeployBadge(percentage, name, isPast=false) {
  const override = DEPLOY_BADGE_CONFIG[name];
  // Upcoming Movements: badges reflect proximity to tipping point
  if (override) {
    const labels = { 'act-now': '🚀 ACT NOW', 'prepare': '🎯 BUILD NOW', 'watch': '👁️ EMERGING', 'dormant': '💤 DORMANT' };
    return `<span class="deploy-badge ${override}">${labels[override]}</span>`;
  }
  if (percentage >= 80) return '<span class="deploy-badge act-now">🚀 ACT NOW</span>';
  if (percentage >= 60) return '<span class="deploy-badge prepare">🎯 BUILD NOW</span>';
  if (percentage >= 40) return '<span class="deploy-badge watch">👁️ EMERGING</span>';
  return '<span class="deploy-badge dormant">💤 DORMANT</span>';
}
function getTrajectoryArrow(name, percentage) {
  const arrow = TRAJECTORY_CONFIG[name];
  if (arrow) {
    const cls = arrow === '↑↑' ? 'up-fast' : arrow === '↑' ? 'up' : arrow === '→' ? 'stable' : arrow === '↓' ? 'down' : 'down-fast';
    return `<span class="trajectory-arrow ${cls}">${arrow}</span>`;
  }
  if (percentage >= 80) return '<span class="trajectory-arrow up-fast">↑↑</span>';
  if (percentage >= 60) return '<span class="trajectory-arrow up">↑</span>';
  return '<span class="trajectory-arrow stable">→</span>';
}

function renderStats() {
  const t = ALL_CASES.length;
  // Calculate average percentage
  const avgPercentage = Math.round(ALL_CASES.reduce((a, c) => a + calculateNCRSScore(c.ncrs).percentage, 0) / t);
  const highNCRS = ALL_CASES.filter(c => calculateNCRSScore(c.ncrs).percentage >= 80).length;
  const wins = ALL_CASES.filter(c => c.outcome_score === 5).length;
  const fail = ALL_CASES.filter(c => c.failed).length;
  document.getElementById('stats-grid').innerHTML = `
    <div class="stat-card"><div class="val">${t}</div><div class="lbl">Total Cases</div></div>
    <div class="stat-card"><div class="val" style="color:var(--accent);">${avgPercentage}%</div><div class="lbl">Avg NCRS Score</div><div class="sub">out of 100%</div></div>
    <div class="stat-card"><div class="val" style="color:var(--warning);">${highNCRS}</div><div class="lbl">High NCRS (80%+)</div></div>
    <div class="stat-card"><div class="val" style="color:var(--success);">${wins}</div><div class="lbl">Full Wins (5)</div></div>
    <div class="stat-card"><div class="val" style="color:var(--danger);">${fail}</div><div class="lbl">Failed Tips</div></div>
`;
}

function renderCaseCard(c, isPast=true) {
  const ncrsScore = calculateNCRSScore(c.ncrs);
  const pctClass = getPercentageClass(ncrsScore.percentage);
  const isEmerging = c.id >= 145;
  const isStillActive = STILL_ACTIVE_IDS && STILL_ACTIVE_IDS.includes(c.id);
  return `<div class="case-card ${c.failed ? 'failed' : ''}" data-id="${c.id}">
    <div class="case-header">
      <span class="case-num">#${c.id}</span>
      <span class="case-name">${c.name}</span>
      ${isEmerging ? '<span class="emerging-badge">NEW</span>' : ''}
      ${isStillActive ? '<span class="still-active-badge">ACTIVE</span>' : ''}
    </div>
    <div class="case-meta"><span>${c.region}</span><span>·</span><span>${c.year}</span>${c.failed ? '<span class="failed-badge">FAILED TIP</span>' : ''}</div>
    ${c.issue ? `<div style="font-size:10px;color:var(--text-muted);margin-bottom:6px;line-height:1.4;">${c.issue.substring(0,90)}${c.issue.length>90?'…':''}</div>` : ''}
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">
      <span class="ncrs-percentage-badge ${pctClass}">${ncrsScore.percentage}%</span>
      ${getTrajectoryArrow(c.name, ncrsScore.percentage)}
      <button class="ncrs-info-btn" onclick="event.stopPropagation();showNCRSRubric(event);">?</button>
    </div>
    <div style="margin:4px 0;">${isPast ? getPastMovementBadge(c) : getDeployBadge(ncrsScore.percentage, c.name)}</div>
    ${c.outcome_score !== undefined ? `<span class="outcome-badge ob-${c.outcome_score}">${outcomeLabel(c.outcome_score)}</span>` : ''}
  </div>`;
}

function renderCases() {
  const s = (currentPage - 1) * PAGE_SIZE;
  const e = s + PAGE_SIZE;
  const v = filteredCases.slice(s, e);
  document.getElementById('results-count').textContent = `Showing ${s + 1}-${Math.min(e, filteredCases.length)} of ${filteredCases.length} cases`;
  document.getElementById('cases-grid').innerHTML = v.map(renderCaseCard).join('');
  const tp = Math.ceil(filteredCases.length / PAGE_SIZE);
  let ph = '';
  for (let i = 1; i <= tp; i++) ph += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
  document.getElementById('pagination').innerHTML = ph;
}

function getStatusForCase(c) {
  if (c.failed) return 'failed';
  const enriched = ENRICHED_DATA && ENRICHED_DATA[String(c.id)];
  const outcomeScore = enriched ? enriched.outcome_score : null;
  const markers = enriched ? (enriched.progress_markers || []) : [];
  const lastType = markers.length ? markers[markers.length-1].type : null;
  if (outcomeScore === 5) return 'norm-changed';
  if (lastType === 'REVERSAL') return 'under-threat';
  if (lastType === 'ONGOING' || outcomeScore >= 3) return 'ongoing';
  if (outcomeScore >= 2) return 'partial';
  return 'resolved';
}

function filterCases() {
  const s = document.getElementById('search-input').value.toLowerCase();
  const r = document.getElementById('filter-region').value;
  const statusFilter = document.getElementById('filter-status') ? document.getElementById('filter-status').value : '';
  const tagFilter = document.getElementById('filter-tag') ? document.getElementById('filter-tag').value : '';
  const m = parseInt(document.getElementById('filter-score').value);
  filteredCases = ALL_CASES.filter(c => {
    if (s && !c.name.toLowerCase().includes(s) && !(c.issue || '').toLowerCase().includes(s)) return false;
    if (r && getRegionGroup(c.region) !== r) return false;
    if (statusFilter && getStatusForCase(c) !== statusFilter) return false;
    if (tagFilter && !(c.tags || []).includes(tagFilter)) return false;
    const ncrsScore = calculateNCRSScore(c.ncrs);
    if (ncrsScore.percentage < m) return false;
    return true;
  });
  sortCases();
  currentPage = 1;
  renderCases();
}

function sortCases() {
  filteredCases.sort((a, b) => {
    if (currentSort === 'num') return a.id - b.id;
    if (currentSort === 'score') return calculateNCRSScore(b.ncrs).percentage - calculateNCRSScore(a.ncrs).percentage;
    if (currentSort === 'outcome') return (b.outcome_score || 0) - (a.outcome_score || 0);
    if (currentSort === 'year') return (parseInt(b.year) || 0) - (parseInt(a.year) || 0);
    return 0;
  });
}

function goToPage(n) { currentPage = n; renderCases(); document.getElementById('page-cases').scrollIntoView({ behavior: 'smooth' }); }

function showNCRSRubric(event) {
  const popup = document.getElementById('ncrs-rubric-popup');
  popup.style.left = (event.clientX - 180) + 'px';
  popup.style.top = (event.clientY + 20) + 'px';
  popup.classList.add('visible');
  setTimeout(() => { document.addEventListener('click', hideNCRSRubric, { once: true }); }, 10);
}

function hideNCRSRubric() { document.getElementById('ncrs-rubric-popup').classList.remove('visible'); }

function openCaseModal(id) {
  currentModalId = id;
  const c = ALL_CASES.find(x => x.id === id);
  if (!c) return;
  const ncrsScore = calculateNCRSScore(c.ncrs);
  const lang = MOVEMENT_LANGUAGE[c.name];
  let langHTML = '';
  if (lang) {
    langHTML = `<div class="language-section">
      <div class="language-section-title">📣 Movement Language</div>
      <div class="language-row"><span class="lbl">Hashtag</span><span class="val">${lang.primaryHashtag}</span></div>
      <div class="language-row"><span class="lbl">Slogan</span><span class="val">${lang.keySlogan}</span></div>
      <div class="language-row"><span class="lbl">Metaphor</span><span class="val">${lang.centralMetaphor}</span></div>
      <div class="language-row"><span class="lbl">Why Worked</span><span class="val">${lang.whyItWorked}</span></div>
      ${lang.whatFailed ? `<div class="language-row"><span class="lbl">What Failed</span><span class="val" style="color:var(--danger);">${lang.whatFailed}</span></div>` : ''}
    </div>`;
  }
  // Pattern match section
  const patternMatch = PRIORITY_MOVEMENTS.find(m => c.name.includes(m.name.split(':')[0]) || m.name.includes(c.name.split(' ')[0]));
  let patternHTML = '';
  if (patternMatch && patternMatch.patternMatch) {
    patternHTML = `<div class="modal-section" style="background:var(--surface2);border-radius:8px;padding:12px;margin-top:12px;">
      <div class="modal-section-title">📊 Pattern Match</div>
      <p><strong>Historical parallel:</strong> ${patternMatch.patternMatch.historical}</p>
      <p><strong>What happened next (18mo):</strong> ${patternMatch.patternMatch.outcome}</p>
      <p><strong>Confidence:</strong> <span style="color:${patternMatch.patternMatch.confidence === 'High' ? 'var(--accent)' : 'var(--warning)'};">${patternMatch.patternMatch.confidence}</span></p>
    </div>`;
  }
  
  // Get enriched data for this case
  const enriched = getEnrichedData(id);
  let enrichedHTML = '';
  if (enriched) {
    enrichedHTML = renderEnrichedTimeline(enriched.progress_markers) +
                   renderEnrichedEcosystem(enriched.key_actors) +
                   renderEnrichedCultural(enriched.cultural_markers) +
                   renderEnrichedChange(enriched.what_actually_changed) +
                   renderEnrichedSources(enriched.sources) +
                   renderEnrichedCrossLinks(enriched.cross_movement_links);
  }
  
  document.getElementById('modal-content').innerHTML = `
    <button class="modal-close">×</button>
    <div class="modal-nav-hint"><kbd>←</kbd><kbd>→</kbd> navigate · <kbd>Esc</kbd> close</div>
    <div class="modal-title">${c.name}</div>
    <div class="modal-meta">
      <span>${c.region}</span><span>·</span><span>${c.year}</span>
      ${c.failed ? '<span class="failed-badge">FAILED TIP</span>' : ''}
      ${c.outcome_score !== undefined ? `<span class="outcome-badge ob-${c.outcome_score}">${outcomeLabel(c.outcome_score)}</span>` : ''}
    </div>
    <div class="modal-section">
      <div class="modal-section-title">
        <span class="ncrs-percentage-badge ${getPercentageClass(ncrsScore.percentage)}">${ncrsScore.percentage}%</span>
        NCRS Score ${getTrajectoryArrow(c.name, ncrsScore.percentage)} ${getDeployBadge(ncrsScore.percentage, c.name)}
        <button class="ncrs-info-btn" onclick="event.stopPropagation();showNCRSRubric(event);">?</button>
      </div>
      ${c.ncrs?.rationale ? `<p style="font-size:11px;color:var(--text-muted);margin-top:6px;">${c.ncrs.rationale}</p>` : ''}
    </div>
    ${renderNCRSBreakdown(ncrsScore)}
    <div class="modal-section"><div class="modal-section-title">Issue</div><p>${c.issue || 'No description available.'}</p></div>
    ${c.trigger ? `<div class="modal-section"><div class="modal-section-title">Trigger Event</div><p>${c.trigger}</p></div>` : ''}
    ${c.outcome ? `<div class="modal-section"><div class="modal-section-title">Outcome</div><p>${c.outcome}</p></div>` : ''}
    ${langHTML}
    ${patternHTML}
    ${c.intervention_levers ? `<div class="intervention-box"><div class="label">🎯 Intervention Levers</div><p>${c.intervention_levers}</p></div>` : ''}
    ${c.description ? `<div class="modal-section"><div class="modal-section-title">📖 What's Happening</div><p style="font-size:12px;line-height:1.8;color:#c8cad8;">${c.description}</p></div>` : ''}
    ${c.whyNow ? `<div class="intervention-box" style="border-color:rgba(255,217,61,0.4);background:linear-gradient(135deg,rgba(255,217,61,0.06),rgba(255,217,61,0.02));"><div class="label" style="color:var(--warning);">⚡ Why Act Now</div><p>${c.whyNow}</p></div>` : ''}
    ${c.regulatoryWindow ? `<div class="modal-section"><div class="modal-section-title">⚖️ Regulatory / Legislative Window</div><p style="font-size:12px;color:#c8cad8;">${c.regulatoryWindow}</p></div>` : ''}
    ${c.keyOrgs && c.keyOrgs.length ? `<div class="modal-section"><div class="modal-section-title">🏛️ Key Organizations</div><div style="display:flex;flex-wrap:wrap;gap:6px;">${c.keyOrgs.map(o => `<a href="${o.url}" target="_blank" style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:5px 10px;color:var(--accent);text-decoration:none;font-size:11px;font-weight:600;">${o.name} ↗</a>`).join('')}</div></div>` : ''}
    ${c.sources && c.sources.length ? `<div class="modal-section"><div class="modal-section-title">📚 Sources</div><div class="enriched-sources">${c.sources.map(s => `<div class="enriched-source-item"><a href="${s.url}" target="_blank" class="enriched-source-link">${s.title}</a></div>`).join('')}</div></div>` : ''}
    ${c.slogans && c.slogans.length ? `<div class="modal-section"><div class="modal-section-title">📣 Movement Language</div><div class="cultural-markers">${c.slogans.map(s => `<span class="cultural-marker ${s.startsWith('#') ? 'hashtag' : 'slogan'}">${s}</span>`).join('')}</div></div>` : ''}
    ${enrichedHTML}
    <div class="modal-action-buttons">
      <button class="modal-action-btn research" onclick="openResearchRequestModal(${c.id}, '${c.name.replace(/'/g, "\\'")}', 'research')">📚 Request Research</button>
      <button class="modal-action-btn bug-report" onclick="openResearchRequestModal(${c.id}, '${c.name.replace(/'/g, "\\'")}', 'bug')">🐛 Report Issue</button>
    </div>`;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); document.body.style.overflow = ''; }

// renderInterventionWindows removed — modal detail now in openForecastModal

function renderForecast() {
  const track = document.getElementById('calendar-track');
  let html = '';
  Object.entries(FORECAST_EVENTS).forEach(([year, events]) => {
    html += `<div class="calendar-year"><div class="calendar-year-title">${year}</div>
      ${events.map((e, i) => `<div class="calendar-event ${e.hot ? 'hot' : ''} ${e.warm ? 'warm' : ''}" onclick="openForecastModal('${year}',${i})" style="min-height:auto;">
        <div class="calendar-event-date">${e.date}</div>
        <div class="calendar-event-title">${e.title}</div>
        ${e.desc ? `<div style="font-size:10px;color:var(--text-muted);margin:4px 0;line-height:1.4;">${e.desc.substring(0,100)}…</div>` : ''}
        <div class="calendar-event-movements" style="margin-top:4px;">${e.movements.map(m => `<span style="display:inline-block;background:rgba(0,212,170,0.1);color:var(--accent);border-radius:3px;padding:1px 5px;margin:1px;font-size:9px;">${m}</span>`).join('')}</div>
        ${e.orgs ? `<div style="font-size:9px;color:var(--text-muted);margin-top:5px;border-top:1px solid var(--border);padding-top:4px;">🤝 ${e.orgs.substring(0,60)}…</div>` : ''}
      </div>`).join('')}</div>`;
  });
  track.innerHTML = html;

  // Render candidates as compact grid cards
  document.getElementById('candidates-list').innerHTML = CANDIDATES.map((c, i) => {
    const ncrsScore = calculateNCRSScore(c.ncrs);
    return `<div class="candidate-card" onclick="openCandidateModal(${i})" style="margin-bottom:0;">
      <div class="candidate-header">
        <div style="flex:1;"><div class="candidate-name" style="font-size:13px;">${c.name}</div><div style="margin-top:4px;">${getDeployBadge(ncrsScore.percentage, c.name)}</div></div>
        <div style="text-align:right;">
          <span class="ncrs-percentage-badge ${getPercentageClass(ncrsScore.percentage)}">${ncrsScore.percentage}%</span>
          ${getTrajectoryArrow(c.name, ncrsScore.percentage)}
        </div>
      </div>
      <div class="candidate-body" style="font-size:11px;color:var(--text-muted);margin-top:6px;line-height:1.5;">${c.desc}</div>
    </div>`;
  }).join('');

  // Render emerging trends (INLINE_CASES_2026 ids 145+)
  renderEmergingTrends();

  // Render still-active historical cases
  renderStillActiveCases();
}

function renderEmergingTrends() {
  const el = document.getElementById('emerging-trends-grid');
  if (!el) return;
  const emerging = INLINE_CASES_2026.filter(c => c.id >= 145);
  if (!emerging.length) {
    el.innerHTML = '<p style="color:var(--text-muted);font-size:12px;">Emerging trend entries will appear here as they are added.</p>';
    return;
  }
  el.innerHTML = emerging.map(c => renderCaseCard(c)).join('');
}

const STILL_ACTIVE_IDS = [1,18,31,38,43,49,57,63,64,67,69,72,77,80,84,94,95,100];

function renderStillActiveCases() {
  const el = document.getElementById('still-active-grid');
  if (!el) return;
  // Wait for cases to be loaded
  if (!casesDataLoaded || !ALL_CASES.length) {
    el.innerHTML = '<p style="color:var(--text-muted);font-size:12px;">Loading cases...</p>';
    return;
  }
  const active = ALL_CASES.filter(c => STILL_ACTIVE_IDS.includes(c.id));
  active.sort((a, b) => calculateNCRSScore(b.ncrs).percentage - calculateNCRSScore(a.ncrs).percentage);
  el.innerHTML = active.map(c => renderCaseCard(c)).join('');
}

function openForecastModal(y, i) {
  const e = FORECAST_EVENTS[y]?.[i];
  if (!e) return;
  
  // Try multiple ways to get enriched data
  let enriched = null;
  
  // 1. Try by enrichedId
  if (e.enrichedId) {
    enriched = getEnrichedData(e.enrichedId);
  }
  
  // 2. Try by event title
  if (!enriched && e.title) {
    enriched = getEnrichedData(e.title.replace(/[🇫🇷✅]/g, '').trim());
  }
  
  // 3. Try by first movement name
  if (!enriched && e.movements && e.movements.length > 0) {
    for (const m of e.movements) {
      enriched = getEnrichedData(m);
      if (enriched) break;
    }
  }
  
  // 4. Fall back to FORECAST_FALLBACK_DATA
  if (!enriched && e.enrichedId) {
    enriched = FORECAST_FALLBACK_DATA[e.enrichedId];
  }
  
  let enrichedHTML = '';
  
  if (enriched) {
    // Timeline
    if (enriched.timeline || enriched.progress_markers) {
      const timeline = enriched.timeline || enriched.progress_markers;
      enrichedHTML += `<div class="modal-section">
        <div class="modal-section-title">📅 Timeline</div>
        <div class="enriched-timeline">
          ${timeline.map(m => `
            <div class="enriched-timeline-item type-${m.type}">
              <span class="enriched-timeline-year">${m.year}</span>
              <span class="enriched-timeline-type ${m.type}">${m.type}</span>
              <div class="enriched-timeline-event">${m.event}</div>
            </div>
          `).join('')}
        </div>
      </div>`;
    }
    
    // Key actors
    if (enriched.key_actors) {
      const actors = Array.isArray(enriched.key_actors) ? enriched.key_actors : [];
      if (actors.length > 0) {
        enrichedHTML += `<div class="modal-section">
          <div class="modal-section-title">👥 Key Actors Mobilizing</div>
          <div class="enriched-actor-list">${actors.map(a => {
            const name = typeof a === 'object' ? a.name : a;
            const verified = typeof a === 'object' ? a.verified : null;
            const badge = verified === true ? '<span style="color:#00d4aa;margin-left:3px;">✓</span>' : verified === 'implied' ? '<span style="color:#ffd93d;margin-left:3px;">~</span>' : '';
            return `<span class="enriched-actor-tag">${name}${badge}</span>`;
          }).join('')}</div>
        </div>`;
      } else {
        enrichedHTML += renderEnrichedEcosystem(enriched.key_actors);
      }
    }
    
    // Sources
    if (enriched.sources && enriched.sources.length > 0) {
      enrichedHTML += renderEnrichedSources(enriched.sources);
    }
    
    // What actually changed
    if (enriched.what_actually_changed) {
      enrichedHTML += renderEnrichedChange(enriched.what_actually_changed);
    }
  }
  
  // Create clickable movement tags
  const movementTags = e.movements.map(m => {
    const caseData = findCaseByName(m);
    if (caseData) {
      return `<span class="intervention-movement-tag clickable" onclick="closeModal();setTimeout(()=>openCaseModal(${caseData.id}),100);">${m}</span>`;
    }
    return `<span class="intervention-movement-tag">${m}</span>`;
  }).join('');
  
  // Generate richer fallback content if no enriched data
  let fallbackHTML = '';
  if (!enriched) {
    // Create inline fallback data based on event info
    fallbackHTML = `
      <div class="modal-section">
        <div class="modal-section-title">📋 Event Context</div>
        <p style="color:#c8cad8;font-size:12px;line-height:1.7;">
          This event represents a critical intervention window. The movements listed above are converging around this moment, 
          creating potential for coordinated action and amplified impact.
        </p>
      </div>
      <div class="modal-section">
        <div class="modal-section-title">🎯 Strategic Considerations</div>
        <ul style="color:#c8cad8;font-size:12px;line-height:1.7;padding-left:18px;">
          <li>Build coalition infrastructure in advance</li>
          <li>Identify shared framing across movements</li>
          <li>Coordinate media and communications strategy</li>
          <li>Prepare rapid response capacity</li>
        </ul>
      </div>
    `;
  }
  
  document.getElementById('modal-content').innerHTML = `
    <button class="modal-close">×</button>
    <div class="modal-title">${e.title}</div>
    <div class="modal-meta">
      <span>${y}</span><span>·</span><span>${e.date}</span>
      ${e.hot ? '<span style="color:var(--danger);font-weight:700;">🔥 HOT</span>' : ''}
      ${e.warm ? '<span style="color:var(--warning);font-weight:700;">⚠️ WARM</span>' : ''}
    </div>
    ${e.desc ? `<div class="modal-section"><div class="modal-section-title">📋 What's Happening</div><p style="font-size:12px;line-height:1.8;color:#c8cad8;">${e.desc}</p></div>` : ''}
    ${e.whyItMatters ? `<div class="intervention-box"><div class="label">⚡ Why It Matters Right Now</div><p>${e.whyItMatters}</p></div>` : ''}
    <div class="modal-section">
      <div class="modal-section-title">🔗 Related Movements (click to view)</div>
      <div class="intervention-movements" style="margin-top:8px;">${movementTags}</div>
    </div>
    ${e.orgs ? `<div class="modal-section"><div class="modal-section-title">🤝 Key Organizations &amp; Partners</div><p style="font-size:12px;color:#c8cad8;">${e.orgs}</p></div>` : ''}
    ${enrichedHTML}
    ${fallbackHTML}
  `;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function openCandidateModal(idx) {
  const c = CANDIDATES[idx];
  if (!c) return;
  const ncrsScore = calculateNCRSScore(c.ncrs);
  
  // Try to get enriched data
  const enriched = getEnrichedData(c.name);
  let enrichedHTML = '';
  if (enriched) {
    enrichedHTML = renderEnrichedTimeline(enriched.progress_markers) +
                   renderEnrichedEcosystem(enriched.key_actors) +
                   renderEnrichedSources(enriched.sources);
  }

  // Rich candidate detail from new fields
  const orgLinksHTML = c.keyOrgs ? `<div class="modal-section">
    <div class="modal-section-title">🏛️ Key Organizations</div>
    <div class="enriched-actor-list" style="gap:6px;">
      ${c.keyOrgs.map(o => `<a href="${o.url}" target="_blank" style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:5px 10px;color:var(--accent);text-decoration:none;font-size:11px;font-weight:600;">${o.name} ↗</a>`).join('')}
    </div>
  </div>` : '';

  const sourcesHTML = c.sources ? `<div class="modal-section">
    <div class="modal-section-title">📚 Sources</div>
    <div class="enriched-sources">
      ${c.sources.map(s => `<div class="enriched-source-item"><a href="${s.url}" target="_blank" class="enriched-source-link">${s.title}</a></div>`).join('')}
    </div>
  </div>` : '';
  
  document.getElementById('modal-content').innerHTML = `
    <button class="modal-close">×</button>
    <div class="modal-title">${c.name}</div>
    <div class="modal-meta">
      <span class="ncrs-percentage-badge ${getPercentageClass(ncrsScore.percentage)}">${ncrsScore.percentage}%</span>
      ${getTrajectoryArrow(c.name, ncrsScore.percentage)}
      ${getDeployBadge(ncrsScore.percentage, c.name)}
    </div>
    ${renderNCRSBreakdown(ncrsScore)}
    <div class="modal-section"><div class="modal-section-title">📋 Current Status</div><p>${c.desc}</p></div>
    ${c.description ? `<div class="modal-section"><div class="modal-section-title">📖 What's Happening</div><p style="font-size:12px;line-height:1.8;color:#c8cad8;">${c.description}</p></div>` : ''}
    ${c.whyNow ? `<div class="intervention-box"><div class="label">⚡ Why Act Now</div><p>${c.whyNow}</p></div>` : ''}
    ${c.regulatoryWindow ? `<div class="modal-section"><div class="modal-section-title">⚖️ Regulatory / Legislative Window</div><p style="font-size:12px;color:#c8cad8;">${c.regulatoryWindow}</p></div>` : ''}
    ${orgLinksHTML}
    ${sourcesHTML}
    ${enrichedHTML}
  `;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

// Ecosystem filter state
let ecoFilter = 'all';
let ecoSearchTerm = '';

function renderEcosystem() {
  // Use ecosystem.json data if loaded, otherwise fallback
  const data = ecosystemDataLoaded && ECOSYSTEM_DATA.domains ? ECOSYSTEM_DATA : ECOSYSTEM_FALLBACK;
  
  // Get all funders from enriched data to cross-reference
  const funderMovements = {};
  if (enrichedDataLoaded && ENRICHED_DATA) {
    Object.values(ENRICHED_DATA).forEach(entry => {
      if (entry.key_actors && entry.key_actors.funders) {
        entry.key_actors.funders.forEach(f => {
          const name = typeof f === 'object' ? f.name : f;
          if (!funderMovements[name]) funderMovements[name] = [];
          funderMovements[name].push(entry.name);
        });
      }
    });
  }
  
  // Filter domains
  let filteredDomains = data.domains || [];
  if (ecoFilter !== 'all') {
    filteredDomains = filteredDomains.filter(d => 
      d.name.toLowerCase().includes(ecoFilter.toLowerCase())
    );
  }
  if (ecoSearchTerm) {
    const term = ecoSearchTerm.toLowerCase();
    filteredDomains = filteredDomains.filter(d => {
      if (d.name.toLowerCase().includes(term)) return true;
      const orgs = d.major_orgs || d.orgs || [];
      return orgs.some(o => o.name.toLowerCase().includes(term));
    });
  }
  
  document.getElementById('domain-grid').innerHTML = filteredDomains.map(d => {
    const orgs = d.major_orgs || d.orgs || [];
    return `<div class="domain-card"><div class="domain-name">${d.name}</div><div class="domain-section-label">Key Organizations</div>
      ${orgs.slice(0, 8).map(o => {
        const movementCount = countOrgMovements(o.name);
        return `<div class="org-item" onclick="openOrgModal('${escapeHtml(o.name)}', '${escapeHtml(d.name)}')">
          <div class="org-name">${o.name}${movementCount > 0 ? `<span class="eco-connection-count">${movementCount} movements</span>` : ''}</div>
          ${o.budget_usd || o.budget ? `<div class="org-budget">${o.budget_usd || o.budget}</div>` : ''}
          ${o.tactics ? `<div class="org-tactics">${o.tactics.substring(0, 100)}...</div>` : ''}
        </div>`;
      }).join('')}
    </div>`;
  }).join('');
  
  // Render funders with DYNAMIC movement counts using comprehensive search
  let filteredFunders = data.funders || [];
  if (data.domains && data.domains[0]?.funding_ecosystem?.top_foundations) {
    filteredFunders = data.domains[0].funding_ecosystem.top_foundations;
  }
  if (ecoSearchTerm) {
    const term = ecoSearchTerm.toLowerCase();
    filteredFunders = filteredFunders.filter(f => f.name.toLowerCase().includes(term));
  }
  
  document.getElementById('funders-grid').innerHTML = filteredFunders.map(f => {
    // Use dynamic search to count movements
    const movementCount = countFunderMovements(f.name);
    const domains = f.domains || (f.focus ? f.focus.split(',').map(x => x.trim()) : []);
    return `<div class="funder-card" onclick="openFunderModal('${escapeHtml(f.name)}')">
      <div class="funder-name">${f.name}${movementCount > 0 ? `<span class="eco-connection-count">${movementCount} movements</span>` : ''}</div>
      <div class="funder-giving">${f.giving || f.annual_grants || '—'}</div>
      <div class="funder-focus">${f.focus || '—'}</div>
      <div class="funder-domains">${domains.map(d => `<span class="funder-domain">${d}</span>`).join('')}</div>
    </div>`;
  }).join('');
}

function escapeHtml(str) {
  return String(str).replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

// ===== COMPREHENSIVE CROSS-REFERENCING =====
// Extract search terms from org/funder names (handles abbreviations, parentheticals, etc.)
function getSearchTerms(name) {
  const terms = [name];
  // Extract abbreviation from parentheses: "ACLU (American Civil Liberties Union)" -> ["ACLU", "American Civil Liberties Union"]
  const parenMatch = name.match(/^(.+?)\s*\((.+)\)$/);
  if (parenMatch) {
    terms.push(parenMatch[1].trim());
    terms.push(parenMatch[2].trim());
  }
  // Reverse pattern: "American Civil Liberties Union (ACLU)"
  const reverseMatch = name.match(/^(.+?)\s*\(([A-Z]{2,})\)$/);
  if (reverseMatch) {
    terms.push(reverseMatch[1].trim());
    terms.push(reverseMatch[2].trim());
  }
  // Extract first word if it's an acronym (all caps, 2-6 chars)
  const firstWord = name.split(/[\s(]/)[0];
  if (firstWord.length >= 2 && firstWord.length <= 6 && firstWord === firstWord.toUpperCase()) {
    terms.push(firstWord);
  }
  // Also add individual significant words (4+ chars)
  const words = name.split(/[\s\-\/()]+/).filter(w => w.length >= 4 && w !== w.toUpperCase());
  words.forEach(w => terms.push(w));
  
  return [...new Set(terms)].filter(t => t.length >= 2);
}

// Find all movements connected to an organization using comprehensive search
function findOrgMovements(orgName) {
  const results = [];
  const searchTerms = getSearchTerms(orgName);
  const seenIds = new Set();
  
  // Search enriched data (full-text search across entire entry)
  if (enrichedDataLoaded && ENRICHED_DATA) {
    for (const [id, entry] of Object.entries(ENRICHED_DATA)) {
      const fullText = JSON.stringify(entry).toLowerCase();
      if (searchTerms.some(term => fullText.includes(term.toLowerCase()))) {
        const numId = parseInt(id);
        if (!seenIds.has(numId)) {
          seenIds.add(numId);
          results.push({ id: numId, name: entry.name, source: 'enriched' });
        }
      }
    }
  }
  
  // Search ALL_CASES (intervention_levers, issue, outcome, etc.)
  if (ALL_CASES && ALL_CASES.length) {
    for (const c of ALL_CASES) {
      if (seenIds.has(c.id)) continue;
      const fullText = JSON.stringify(c).toLowerCase();
      if (searchTerms.some(term => fullText.includes(term.toLowerCase()))) {
        seenIds.add(c.id);
        results.push({ id: c.id, name: c.name, source: 'cases' });
      }
    }
  }
  
  return results;
}

// Find all movements connected to a funder using comprehensive search
function findFunderMovements(funderName) {
  const results = [];
  const searchTerms = getSearchTerms(funderName);
  const seenIds = new Set();
  
  // Search enriched data funders array and full text
  if (enrichedDataLoaded && ENRICHED_DATA) {
    for (const [id, entry] of Object.entries(ENRICHED_DATA)) {
      let matched = false;
      
      // Check funders array specifically
      if (entry.key_actors && entry.key_actors.funders) {
        matched = entry.key_actors.funders.some(f => {
          const fName = typeof f === 'object' ? f.name : f;
          const fLower = fName.toLowerCase();
          return searchTerms.some(term => 
            fLower.includes(term.toLowerCase()) || term.toLowerCase().includes(fLower)
          );
        });
      }
      
      // Also do full-text search
      if (!matched) {
        const fullText = JSON.stringify(entry).toLowerCase();
        matched = searchTerms.some(term => fullText.includes(term.toLowerCase()));
      }
      
      if (matched) {
        const numId = parseInt(id);
        if (!seenIds.has(numId)) {
          seenIds.add(numId);
          results.push({ id: numId, name: entry.name, source: 'enriched' });
        }
      }
    }
  }
  
  // Search ALL_CASES
  if (ALL_CASES && ALL_CASES.length) {
    for (const c of ALL_CASES) {
      if (seenIds.has(c.id)) continue;
      const fullText = JSON.stringify(c).toLowerCase();
      if (searchTerms.some(term => fullText.includes(term.toLowerCase()))) {
        seenIds.add(c.id);
        results.push({ id: c.id, name: c.name, source: 'cases' });
      }
    }
  }
  
  return results;
}

function countOrgMovements(orgName) {
  return findOrgMovements(orgName).length;
}

function countFunderMovements(funderName) {
  return findFunderMovements(funderName).length;
}

function openOrgModal(orgName, domainName) {
  // Use comprehensive search to find all movements this org is connected to
  const movements = findOrgMovements(orgName);
  
  // Find org details from ecosystem data
  let orgDetails = null;
  const data = ecosystemDataLoaded && ECOSYSTEM_DATA.domains ? ECOSYSTEM_DATA : ECOSYSTEM_FALLBACK;
  data.domains?.forEach(d => {
    const orgs = d.major_orgs || d.orgs || [];
    const found = orgs.find(o => o.name === orgName);
    if (found) orgDetails = found;
  });
  
  // Show search terms used for transparency
  const searchTerms = getSearchTerms(orgName);
  
  document.getElementById('modal-content').innerHTML = `
    <button class="modal-close">×</button>
    <div class="modal-title">🏛️ ${orgName}</div>
    <div class="modal-meta"><span>Domain: ${domainName}</span></div>
    ${orgDetails ? `
      <div class="modal-section">
        <div class="modal-section-title">Organization Details</div>
        ${orgDetails.budget_usd || orgDetails.budget ? `<p><strong>Budget:</strong> ${orgDetails.budget_usd || orgDetails.budget}</p>` : ''}
        ${orgDetails.tactics ? `<p><strong>Tactics:</strong> ${orgDetails.tactics}</p>` : ''}
        ${orgDetails.key_wins ? `<p><strong>Key Wins:</strong> ${orgDetails.key_wins.join(', ')}</p>` : ''}
      </div>
    ` : ''}
    <div class="modal-section">
      <div class="modal-section-title">Connected Movements (${movements.length})</div>
      ${movements.length > 0 ? `
        <div class="enriched-cross-links">
          ${movements.map(m => `
            <div class="enriched-cross-link" onclick="closeModal();setTimeout(()=>openCaseModal(${m.id}),100);">
              <div class="enriched-cross-link-name">${m.name}</div>
              <div class="enriched-cross-link-rel" style="font-size:9px;color:var(--text-muted);">Found via: ${m.source}</div>
            </div>
          `).join('')}
        </div>
      ` : `<p style="color:var(--text-muted);">No movement connections found.</p>`}
      <p style="font-size:10px;color:var(--text-muted);margin-top:10px;">Search terms: ${searchTerms.join(', ')}</p>
    </div>
  `;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function openFunderModal(funderName) {
  // Use comprehensive search to find all movements this funder is connected to
  const movements = findFunderMovements(funderName);
  
  // Find funder details
  let funderDetails = null;
  const data = ecosystemDataLoaded && ECOSYSTEM_DATA.domains ? ECOSYSTEM_DATA : ECOSYSTEM_FALLBACK;
  const funders = data.funders || (data.domains?.[0]?.funding_ecosystem?.top_foundations) || [];
  const searchName = funderName.toLowerCase().trim();
  funderDetails = funders.find(f => f.name === funderName) || 
                  funders.find(f => f.name.toLowerCase().includes(searchName));
  
  // Show search terms used for transparency
  const searchTerms = getSearchTerms(funderName);
  
  document.getElementById('modal-content').innerHTML = `
    <button class="modal-close">×</button>
    <div class="modal-title">💰 ${funderName}</div>
    ${funderDetails ? `
      <div class="modal-meta">
        <span style="color:var(--success);font-weight:700;">${funderDetails.giving || funderDetails.annual_grants || '—'}</span>
      </div>
      <div class="modal-section">
        <div class="modal-section-title">Focus Areas</div>
        <p>${funderDetails.focus || '—'}</p>
        ${funderDetails.domains ? `<div class="funder-domains" style="margin-top:8px;">${funderDetails.domains.map(d => `<span class="funder-domain">${d}</span>`).join('')}</div>` : ''}
      </div>
    ` : ''}
    <div class="modal-section">
      <div class="modal-section-title">Connected Movements (${movements.length})</div>
      ${movements.length > 0 ? `
        <div class="enriched-cross-links">
          ${movements.map(m => `
            <div class="enriched-cross-link" onclick="closeModal();setTimeout(()=>openCaseModal(${m.id}),100);">
              <div class="enriched-cross-link-name">${m.name}</div>
              <div class="enriched-cross-link-rel" style="font-size:9px;color:var(--text-muted);">Found via: ${m.source}</div>
            </div>
          `).join('')}
        </div>
      ` : `<p style="color:var(--text-muted);">No movement connections found.</p>`}
      <p style="font-size:10px;color:var(--text-muted);margin-top:10px;">Search terms: ${searchTerms.join(', ')}</p>
    </div>
  `;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function renderIntelligenceBriefing() {
  // actor-grid and pattern-grid now live in page-upcoming
  const actorEl = document.getElementById('actor-grid');
  if (!actorEl) return;

  actorEl.innerHTML = KEY_ACTORS.map(v => {
    // Make actor movements clickable
    const movementTags = v.movements.map(m => {
      const caseData = findCaseByName(m);
      if (caseData) {
        return `<span class="actor-movement-tag" style="cursor:pointer;" onclick="openCaseModal(${caseData.id})">${m}</span>`;
      }
      return `<span class="actor-movement-tag">${m}</span>`;
    }).join('');
    
    return `<div class="actor-card">
      <div class="actor-name">${v.name}</div>
      <div class="actor-movements">${movementTags}</div>
      <div class="actor-harm"><strong>Impact:</strong> ${v.harm}</div>
      <div class="actor-claim">${v.claim}</div>
      <div class="actor-leverage"><div class="actor-leverage-label">🎯 Leverage Points</div><div class="actor-leverage-text">${v.leverage}</div></div>
    </div>`;
  }).join('');
  
  document.getElementById('pattern-grid').innerHTML = HISTORICAL_PATTERNS.map(p => {
    // Make pattern movement name clickable
    const caseData = findCaseByName(p.movement);
    const movementHTML = caseData 
      ? `<span class="movement-link" onclick="openCaseModal(${caseData.id})">${p.movement}</span>`
      : p.movement;
    
    return `<div class="pattern-card">
      <div class="pattern-movement">${movementHTML} <span style="font-size:10px;color:${p.confidence === 'High' ? 'var(--accent)' : 'var(--warning)'};">(${p.confidence})</span></div>
      <div class="pattern-text">${p.pattern}</div>
    </div>`;
  }).join('');
}

function showTab(tabId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + tabId).classList.add('active');
  // Only highlight nav tab if it exists (about page has no visible tab)
  const navTab = document.querySelector(`[data-tab="${tabId}"]`);
  if (navTab) navTab.classList.add('active');
  
  // Animate NCRS bars on about page
  if (tabId === 'about') {
    animateAboutNCRSBars();
    animateAboutDimCards();
  }
}

function animateAboutNCRSBars() {
  const fills = document.querySelectorAll('.about-ncrs-fill');
  fills.forEach((fill, i) => {
    fill.style.width = '0';
    setTimeout(() => {
      const targetWidth = fill.dataset.value || 50;
      fill.style.width = targetWidth + '%';
    }, 300 + (i * 100));
  });
}

function animateAboutDimCards() {
  const cards = document.querySelectorAll('.about-dim-card');
  // Use IntersectionObserver for scroll-based reveal
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, index * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    cards.forEach(card => {
      card.classList.remove('visible');
      card.style.opacity = '0';
      card.style.transform = 'translateY(16px)';
      observer.observe(card);
    });
  } else {
    // Fallback: just show all cards
    cards.forEach((card, i) => {
      setTimeout(() => { card.classList.add('visible'); }, 200 + (i * 80));
    });
  }
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => {
  document.querySelector('nav').addEventListener('click', (e) => { const tab = e.target.closest('.nav-tab'); if (tab && tab.dataset.tab) showTab(tab.dataset.tab); });
  
  document.getElementById('cases-grid').addEventListener('click', (e) => { const card = e.target.closest('.case-card'); if (card && card.dataset.id) openCaseModal(parseInt(card.dataset.id)); });
  document.getElementById('emerging-trends-grid').addEventListener('click', (e) => { const card = e.target.closest('.case-card'); if (card && card.dataset.id) openCaseModal(parseInt(card.dataset.id)); });
  document.getElementById('still-active-grid').addEventListener('click', (e) => { const card = e.target.closest('.case-card'); if (card && card.dataset.id) openCaseModal(parseInt(card.dataset.id)); });
  
  document.querySelector('.eco-tabs').addEventListener('click', (e) => {
    const btn = e.target.closest('.eco-tab-btn');
    if (btn && btn.dataset.eco) {
      document.querySelectorAll('.eco-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.eco-tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('eco-' + btn.dataset.eco).classList.add('active');
    }
  });
  
  // Ecosystem filters
  document.querySelector('.eco-filters').addEventListener('click', (e) => {
    const btn = e.target.closest('.eco-filter-tag');
    if (btn && btn.dataset.ecoFilter) {
      document.querySelectorAll('.eco-filter-tag').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      ecoFilter = btn.dataset.ecoFilter;
      renderEcosystem();
    }
  });
  
  document.getElementById('eco-search').addEventListener('input', (e) => {
    ecoSearchTerm = e.target.value;
    renderEcosystem();
  });
  
  const regions = ['Americas', 'Africa/MENA', 'Asia/Pacific', 'Europe', 'Global'];
  const regionSelect = document.getElementById('filter-region');
  regions.forEach(r => regionSelect.innerHTML += `<option value="${r}">${r}</option>`);
  
  document.getElementById('search-input').addEventListener('input', filterCases);
  document.getElementById('filter-region').addEventListener('change', filterCases);
  if(document.getElementById('filter-status')) document.getElementById('filter-status').addEventListener('change', filterCases);

  if(document.getElementById('filter-tag')) document.getElementById('filter-tag').addEventListener('change', filterCases);
  // filter-outcome element removed — status filter handles this now
  // document.getElementById('filter-outcome').addEventListener('change', filterCases);
  document.getElementById('filter-score').addEventListener('input', function() { document.getElementById('score-val').textContent = this.value + '%'; filterCases(); });
  document.getElementById('reset-filters').addEventListener('click', () => {
    document.getElementById('search-input').value = '';
    document.getElementById('filter-region').value = '';
    // document.getElementById('filter-outcome').value = '';
    document.getElementById('filter-score').value = 0;
    document.getElementById('score-val').textContent = '0%';
    filterCases();
  });
  
  document.querySelector('.filters').parentElement.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-sort]');
    if (btn && btn.dataset.sort) {
      document.querySelectorAll('[data-sort]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentSort = btn.dataset.sort;
      sortCases();
      renderCases();
    }
  });
  
  document.getElementById('modal-overlay').addEventListener('click', (e) => { if (e.target === e.currentTarget || e.target.closest('.modal-close')) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && document.getElementById('modal-overlay').classList.contains('open')) closeModal(); });
  document.getElementById('pagination').addEventListener('click', (e) => { const btn = e.target.closest('.page-btn'); if (btn && btn.dataset.page) goToPage(parseInt(btn.dataset.page)); });
  
  // Sort by NCRS percentage (highest first) by default
  currentSort = 'score';
  
  // Animate about page on initial load (page-about is default active)
  // Use requestAnimationFrame for smoother initial animation
  requestAnimationFrame(() => {
    setTimeout(() => {
      animateAboutNCRSBars();
      animateAboutDimCards();
    }, 300);
  });
  
  // Load cases.json data - this will call renderStats/renderCases after loading
  loadCasesData();
  
  // Render sections that don't depend on cases.json
  renderForecast();
  renderEcosystem();
  renderIntelligenceBriefing();
});

// ===== KEYBOARD NAVIGATION =====
let currentModalId = null;

// openCaseModal tracking handled inline

function getNavList() {
  // Determine which list to navigate based on active page
  const upcomingActive = document.getElementById('page-upcoming') && document.getElementById('page-upcoming').classList.contains('active');
  const pastActive = document.getElementById('page-cases') && document.getElementById('page-cases').classList.contains('active');
  if (upcomingActive) {
    // Combine emerging trends + candidates + still-active
    return ALL_CASES.filter(c => c.id >= 101).sort((a,b) => (b.ncrs?.overall_readiness||0) - (a.ncrs?.overall_readiness||0));
  }
  if (pastActive) {
    return [...filteredCases];
  }
  return ALL_CASES;
}

document.addEventListener('keydown', (e) => {
  const modal = document.getElementById('modal-overlay');
  const isOpen = modal && modal.classList.contains('open');

  // Escape closes modal
  if (e.key === 'Escape' && isOpen) {
    closeModal();
    return;
  }

  if (!isOpen || currentModalId === null) return;

  const list = getNavList();
  const currentIndex = list.findIndex(c => c.id === currentModalId);
  if (currentIndex === -1) return;

  let nextId = null;

  if (e.key === 'ArrowRight') {
    e.preventDefault();
    const next = list[currentIndex + 1];
    if (next) nextId = next.id;
  } else if (e.key === 'ArrowLeft') {
    e.preventDefault();
    const prev = list[currentIndex - 1];
    if (prev) nextId = prev.id;
  } else if (e.key === 'ArrowDown') {
    e.preventDefault();
    const overlay = document.getElementById('modal-overlay');
    if (overlay) overlay.scrollBy({ top: 120, behavior: 'smooth' });
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    const overlay = document.getElementById('modal-overlay');
    if (overlay) overlay.scrollBy({ top: -120, behavior: 'smooth' });
  }

  if (nextId !== null) {
    openCaseModal(nextId);
    // Scroll modal back to top
    const overlay = document.getElementById('modal-overlay');
    if (overlay) overlay.scrollTop = 0;
  }
});

</script>

<!-- Report Floating Action Button -->
<button class="report-fab" id="report-fab" title="Suggest a correction">📝</button>

<!-- Report Modal -->
<!-- ===== RESEARCH REQUEST MODAL ===== -->
<div class="research-modal-overlay" id="research-modal-overlay">
  <div class="research-modal">
    <button class="research-modal-close" onclick="closeResearchModal()">×</button>
    <div class="research-modal-title" id="research-modal-title">📚 Request Additional Research</div>
    <div class="research-modal-subtitle">Submit a request for deeper research, source verification, or report an issue with this case.</div>
    
    <div class="research-case-context">
      <span>📋</span>
      <span id="research-case-name"></span>
      <span class="case-id" id="research-case-id"></span>
    </div>
    
    <div class="research-form-group">
      <label class="research-form-label" for="research-type">Request Type</label>
      <select class="research-form-select" id="research-type">
        <option value="Deep research">Deep research</option>
        <option value="Source verification">Source verification</option>
        <option value="Update data">Update data</option>
        <option value="Add missing info">Add missing info</option>
        <option value="Bug/error report">Bug/error report</option>
      </select>
    </div>
    
    <div class="research-form-group">
      <label class="research-form-label" for="research-description">Description</label>
      <textarea class="research-form-textarea" id="research-description" placeholder="What specifically needs research or fixing? Be as detailed as possible..."></textarea>
    </div>
    
    <div class="research-form-group">
      <label class="research-form-label">Priority</label>
      <div class="research-priority-pills">
        <button class="research-priority-pill active" data-priority="normal" onclick="setResearchPriority(this)">Normal</button>
        <button class="research-priority-pill urgent" data-priority="urgent" onclick="setResearchPriority(this)">🔥 Urgent</button>
      </div>
    </div>
    
    <button class="research-submit-btn" id="research-submit-btn" onclick="submitResearchRequest()">Submit Request</button>
    <div class="research-status" id="research-status"></div>
  </div>
</div>

<script>
// ===== RESEARCH REQUEST FUNCTIONALITY =====
(function() {
  let researchCaseId = null;
  let researchCaseName = null;
  let researchPriority = 'normal';

  window.openResearchRequestModal = function(caseId, caseName, mode) {
    researchCaseId = caseId;
    researchCaseName = caseName;
    researchPriority = 'normal';

    document.getElementById('research-case-name').textContent = caseName;
    document.getElementById('research-case-id').textContent = '#' + caseId;
    document.getElementById('research-description').value = '';
    document.getElementById('research-status').className = 'research-status';
    document.getElementById('research-status').style.display = 'none';
    document.getElementById('research-submit-btn').disabled = false;
    document.getElementById('research-submit-btn').textContent = 'Submit Request';

    // Reset priority pills
    document.querySelectorAll('.research-priority-pill').forEach(p => p.classList.remove('active'));
    document.querySelector('.research-priority-pill[data-priority="normal"]').classList.add('active');

    if (mode === 'bug') {
      document.getElementById('research-modal-title').textContent = '🐛 Report Issue';
      document.getElementById('research-type').value = 'Bug/error report';
      document.getElementById('research-description').placeholder = 'What\'s wrong? Describe the factual error, broken link, or outdated information...';
    } else {
      document.getElementById('research-modal-title').textContent = '📚 Request Additional Research';
      document.getElementById('research-type').value = 'Deep research';
      document.getElementById('research-description').placeholder = 'What specifically needs research? Be as detailed as possible...';
    }

    document.getElementById('research-modal-overlay').classList.add('open');
    document.getElementById('research-description').focus();
  };

  window.closeResearchModal = function() {
    document.getElementById('research-modal-overlay').classList.remove('open');
  };

  window.setResearchPriority = function(el) {
    document.querySelectorAll('.research-priority-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
    researchPriority = el.dataset.priority;
  };

  window.submitResearchRequest = async function() {
    const description = document.getElementById('research-description').value.trim();
    const type = document.getElementById('research-type').value;
    const statusEl = document.getElementById('research-status');
    const submitBtn = document.getElementById('research-submit-btn');

    if (!description) {
      statusEl.textContent = 'Please enter a description.';
      statusEl.className = 'research-status error';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    statusEl.style.display = 'none';

    try {
      const response = await fetch('/api/requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          caseId: researchCaseId,
          caseName: researchCaseName,
          type: type,
          description: description,
          priority: researchPriority
        })
      });

      if (response.ok || response.status === 201) {
        statusEl.textContent = '✓ Request submitted! We\'ll review and prioritize.';
        statusEl.className = 'research-status success';
        submitBtn.textContent = 'Submitted!';
        setTimeout(() => closeResearchModal(), 2000);
      } else if (response.status === 429) {
        statusEl.textContent = 'Too many requests. Please wait a moment.';
        statusEl.className = 'research-status error';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Request';
      } else {
        throw new Error('Server error');
      }
    } catch (err) {
      statusEl.textContent = 'Something went wrong. Try again.';
      statusEl.className = 'research-status error';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request';
    }
  };

  // Close on overlay click
  document.getElementById('research-modal-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeResearchModal();
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && document.getElementById('research-modal-overlay').classList.contains('open')) {
      closeResearchModal();
    }
  });
})();
</script>

<div class="report-modal-overlay" id="report-modal-overlay">
  <div class="report-modal">
    <button class="report-modal-close" id="report-modal-close">×</button>
    <div class="report-modal-title">Suggest a correction</div>
    <div class="report-modal-subtitle">Help us keep the data accurate. Paste a link, share a fact, or describe what's wrong.</div>
    
    <div class="report-context" id="report-context" style="display:none;">
      Reporting on: <strong id="report-case-name"></strong>
    </div>
    
    <div class="report-type-pills" id="report-type-pills">
      <button class="report-type-pill active" data-type="wrong_source">Wrong source</button>
      <button class="report-type-pill" data-type="missing_info">Missing info</button>
      <button class="report-type-pill" data-type="incorrect_fact">Incorrect fact</button>
      <button class="report-type-pill" data-type="add_connection">Add connection</button>
      <button class="report-type-pill" data-type="general">General</button>
    </div>
    
    <label class="report-field-label" for="report-message">Message</label>
    <textarea class="report-textarea" id="report-message" placeholder="What did you notice? Paste a link, quote a source, or just describe it..."></textarea>
    
    <label class="report-field-label" for="report-url">Source Link (optional)</label>
    <input type="url" class="report-input" id="report-url" placeholder="https://...">
    
    <button class="report-submit-btn" id="report-submit-btn">Submit Report</button>
    
    <div class="report-status" id="report-status"></div>
  </div>
</div>

<script>
// ===== REPORT FORM FUNCTIONALITY =====
(function() {
  const fab = document.getElementById('report-fab');
  const overlay = document.getElementById('report-modal-overlay');
  const closeBtn = document.getElementById('report-modal-close');
  const pills = document.getElementById('report-type-pills');
  const submitBtn = document.getElementById('report-submit-btn');
  const statusEl = document.getElementById('report-status');
  const contextEl = document.getElementById('report-context');
  const caseNameEl = document.getElementById('report-case-name');
  const messageEl = document.getElementById('report-message');
  const urlEl = document.getElementById('report-url');
  
  let selectedType = 'wrong_source';
  let reportCaseId = null;
  let reportCaseName = null;
  
  function openReportModal() {
    // Check if a case modal is open to get context
    const caseModal = document.getElementById('modal-overlay');
    if (caseModal && caseModal.classList.contains('open') && typeof currentModalId !== 'undefined' && currentModalId !== null) {
      const caseData = ALL_CASES.find(c => c.id === currentModalId);
      if (caseData) {
        reportCaseId = caseData.id;
        reportCaseName = caseData.name;
        caseNameEl.textContent = caseData.name;
        contextEl.style.display = 'block';
      }
    } else {
      reportCaseId = null;
      reportCaseName = null;
      contextEl.style.display = 'none';
    }
    
    // Reset form
    messageEl.value = '';
    urlEl.value = '';
    statusEl.className = 'report-status';
    statusEl.style.display = 'none';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Submit Report';
    
    // Reset pills
    document.querySelectorAll('.report-type-pill').forEach(p => p.classList.remove('active'));
    document.querySelector('.report-type-pill[data-type="wrong_source"]').classList.add('active');
    selectedType = 'wrong_source';
    
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    messageEl.focus();
  }
  
  function closeReportModal() {
    overlay.classList.remove('open');
    // Don't restore body overflow if case modal is still open
    const caseModal = document.getElementById('modal-overlay');
    if (!caseModal || !caseModal.classList.contains('open')) {
      document.body.style.overflow = '';
    }
  }
  
  fab.addEventListener('click', openReportModal);
  
  closeBtn.addEventListener('click', closeReportModal);
  
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeReportModal();
  });
  
  // Handle pill selection
  pills.addEventListener('click', (e) => {
    const pill = e.target.closest('.report-type-pill');
    if (pill) {
      document.querySelectorAll('.report-type-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      selectedType = pill.dataset.type;
    }
  });
  
  // Handle form submission
  submitBtn.addEventListener('click', async () => {
    const message = messageEl.value.trim();
    
    if (!message) {
      statusEl.textContent = 'Please enter a message.';
      statusEl.className = 'report-status error';
      return;
    }
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    statusEl.style.display = 'none';
    
    const payload = {
      reportType: selectedType,
      message: message
    };
    
    if (reportCaseId) payload.caseId = reportCaseId;
    if (reportCaseName) payload.caseName = reportCaseName;
    if (urlEl.value.trim()) payload.url = urlEl.value.trim();
    
    try {
      const response = await fetch('/submit-report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      
      if (response.ok) {
        statusEl.textContent = '✓ Report received. We\'ll review and update.';
        statusEl.className = 'report-status success';
        submitBtn.textContent = 'Submitted!';
        
        // Auto-close after success
        setTimeout(() => {
          closeReportModal();
        }, 2000);
      } else {
        throw new Error('Server error');
      }
    } catch (err) {
      statusEl.textContent = 'Something went wrong. Try again.';
      statusEl.className = 'report-status error';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Report';
    }
  });
  
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) {
      closeReportModal();
    }
  });
  
  // Expose to global scope for onclick handlers in HTML
  window.openReportModal = openReportModal;
})();
</script>
</body>
</html>