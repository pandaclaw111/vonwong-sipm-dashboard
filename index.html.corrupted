const CASES = [
  {"id":1,"name":"MeToo","region":"United States/Global","year":2017,"failed":false,"issue":"Systemic sexual harassment and assault normalized across institutions worldwide.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":4,"trigger":5,"total":21},"tags":["participatory-structure","manufactured-permission","institutional-trigger"],"trigger":"Ronan Farrow's Harvey Weinstein exposé in New Yorker/NYT (Oct 5-10, 2017) + Alyssa Milano's tweet inviting survivors to reply \"Me too\" — Oct 15, 2017.","outcome":"19 million tweets in 24 hours. Dozens of high-profile firings and resignations. NDA reform in 12+ states. Weinstein convicted 2020 (NY conviction overturned 2024). Speak Out Act 2022.","benjamin":"The mechanism embedded IN the trigger (hashtag = invitation to participate) multiplied reach exponentially — design visual interventions that invite contribution, not just consumption.","outcome_score":4,"funders":["Ford Foundation","Open Society Foundations","Time Warner Foundation"],"orgs":["Time's Up","RAINN","MeToo Movement"],"timeline":[{"year":2006,"type":"BUILDUP","event":"Tarana Burke coins 'Me Too' on Myspace"},{"year":2017,"type":"TIP","event":"Weinstein exposé + Milano tweet"},{"year":2020,"type":"WIN","event":"Weinstein convicted"},{"year":2024,"type":"REVERSAL","event":"NY conviction overturned"}]},
  {"id":2,"name":"Black Lives Matter — 2020 Tipping","region":"United States/Global","year":2020,"failed":false,"issue":"Police violence against Black Americans as state-sanctioned racial violence.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":4,"trigger":5,"total":24},"tags":["visual-simplification","compound-crisis","infrastructure-determines-magnitude","cross-border-contagion"],"trigger":"Bystander video of Derek Chauvin kneeling on George Floyd's neck for 8:46 minutes, May 25, 2020.","outcome":"15-26 million US participants — largest protest in American history. $10.6 billion pledged. 4,000+ protests in 60 countries. Chauvin convicted 2021. Most 'defund' measures later reversed.","benjamin":"Seven years of infrastructure made the 2020 tip enormous — campaigns that seem to fail are building the precondition for the next, larger tip.","outcome_score":3,"funders":["Ford Foundation","MacArthur Foundation","Open Society Foundations"],"orgs":["Movement for Black Lives","Color of Change","NAACP"],"timeline":[{"year":2013,"type":"BUILDUP","event":"BLM founded after Trayvon Martin"},{"year":2020,"type":"TIP","event":"George Floyd killing"},{"year":2020,"type":"WIN","event":"Largest protests in US history"},{"year":2021,"type":"WIN","event":"Chauvin convicted"},{"year":2021,"type":"REVERSAL","event":"Minneapolis voters reject police reform"}]},
  {"id":3,"name":"Plastic Straw / Sea Turtle","region":"Global","year":2018,"failed":false,"issue":"Single-use plastic's impact on marine ecosystems.","scores":{"grievance":3,"narrative":3,"infrastructure":3,"permission":3,"trigger":5,"total":17},"tags":["visual-simplification","slow-violence-made-visible","manufactured-permission"],"trigger":"2015 video of marine biologist removing plastic straw from sea turtle nostril — 28 million views.","outcome":"Plastic straw bans in 70+ countries. Major corporations eliminated straws. But straws = 0.025% of ocean plastic. Narrative win exceeded material win.","benjamin":"A specific, visceral, small thing can unlock action on a large abstract thing — but only if organizational infrastructure is ready to convert attention into policy demand.","outcome_score":3,"funders":["Break Free From Plastic members"],"orgs":["Ocean Conservancy","Surfrider Foundation"],"timeline":[{"year":2015,"type":"TIP","event":"Turtle video goes viral"},{"year":2018,"type":"WIN","event":"Starbucks, McDonald's eliminate straws"}]},
  {"id":4,"name":"Fridays for Future","region":"Global","year":2018,"failed":false,"issue":"Government inaction on climate change despite scientific consensus.","scores":{"grievance":4,"narrative":5,"infrastructure":3,"permission":5,"trigger":5,"total":22},"tags":["manufactured-permission","participatory-structure","cross-border-contagion"],"trigger":"Greta Thunberg's solo strike outside Swedish parliament, August 2018. Global tip: September 2019 Climate Strike — 6 million in 185 countries.","outcome":"6 million participants Sept 2019. 'Climate emergency' declarations in 2,000+ jurisdictions. Youth as climate political actors normalized.","benjamin":"Manufactured permission structures (reframing 'truancy' as moral necessity) can unlock mass participation that awareness-raising alone doesn't achieve.","outcome_score":3,"funders":["Climate Emergency Fund","350.org"],"orgs":["Fridays for Future","Sunrise Movement"],"timeline":[{"year":2018,"type":"TIP","event":"Greta's first strike"},{"year":2019,"type":"WIN","event":"6M global climate strike"}]},
  {"id":5,"name":"Standing Rock / #NoDAPL","region":"United States","year":2016,"failed":false,"issue":"Dakota Access Pipeline threatening Standing Rock Sioux water supply and treaty rights.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":3,"trigger":4,"total":19},"tags":["visual-simplification","identity-threat","asymmetric-protection"],"trigger":"September 2016: private security dogs attacking water protectors. Video echoed civil rights era imagery.","outcome":"Obama halted pipeline (Dec 2016). Trump approved it (Jan 2017). Pipeline completed. Cultural impact lasting: Land Back movement acceleration, alliance-building.","benjamin":"Visual resonance with historical injustice is a powerful amplifier — an image that echoes prior recognized injustice mobilizes people who identify with the prior fight.","outcome_score":2,"funders":["First Nations Development Institute","Honor the Earth"],"orgs":["Standing Rock Sioux Tribe","Indigenous Environmental Network"],"timeline":[{"year":2016,"type":"TIP","event":"Dogs attack water protectors"},{"year":2016,"type":"WIN","event":"Obama halts pipeline"},{"year":2017,"type":"REVERSAL","event":"Trump approves pipeline"}]},
  {"id":6,"name":"Marriage Equality — The Long Arc","region":"United States","year":2015,"failed":false,"issue":"Legal recognition of same-sex marriage.","scores":{"grievance":4,"narrative":5,"infrastructure":5,"permission":5,"trigger":4,"total":23},"tags":["deliberate-engineering","manufactured-permission","institutional-trigger"],"trigger":"Supreme Court's Windsor (2013) and Obergefell (2015) decisions, after public opinion crossed 50% support ~2011.","outcome":"Nationwide marriage equality June 2015. Public support: 27% (1996) → 62% (2015). Legal tipping followed cultural tipping by ~3 years.","benjamin":"Cultural tipping can be deliberately engineered through sustained narrative work — the movement didn't wait for a trigger; it built the permission structure over decades.","outcome_score":5,"funders":["Gill Foundation","Arcus Foundation","Ford Foundation"],"orgs":["Lambda Legal","Freedom to Marry","Human Rights Campaign"],"timeline":[{"year":1993,"type":"BUILDUP","event":"Hawaii case begins"},{"year":2013,"type":"WIN","event":"Windsor strikes DOMA"},{"year":2015,"type":"WIN","event":"Obergefell - nationwide equality"}]},
  {"id":7,"name":"Chile Estallido Social","region":"Chile","year":2019,"failed":false,"issue":"Accumulated economic inequality, privatized infrastructure, and elite impunity in Chile's neoliberal model.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":3,"trigger":5,"total":20},"tags":["economic-shock-trigger","identity-threat","compound-crisis"],"trigger":"October 18, 2019: subway fare increase of 30 pesos ($0.04). Student fare evasion met with military force.","outcome":"Government agreed to constitutional convention. New constitutions drafted 2021-2022 but rejected by referendums. Political landscape permanently altered; Boric government elected.","benjamin":"A tiny, absurd trigger (4-cent fare increase) can detonate accumulated decades of grievance — the trigger doesn't need to be proportionate to the outcome.","outcome_score":3,"funders":["Chilean civil society"],"orgs":["No+AFP movement","Feminist collectives"],"timeline":[{"year":2019,"type":"TIP","event":"Metro fare protests explode"},{"year":2020,"type":"WIN","event":"Constitutional referendum passes 78%"},{"year":2022,"type":"SETBACK","event":"New constitution rejected"}]},
  {"id":8,"name":"EndSARS Nigeria","region":"Nigeria","year":2020,"failed":false,"issue":"SARS police unit's systematic torture, extrajudicial killings, and extortion of young Nigerians.","scores":{"grievance":5,"narrative":5,"infrastructure":4,"permission":3,"trigger":5,"total":22},"tags":["visual-simplification","institutional-trigger","identity-threat"],"trigger":"October 3, 2020: video of SARS officers killing a young man in Delta State went viral on Twitter.","outcome":"SARS officially disbanded Oct 11, 2020. Lekki Toll Gate massacre Oct 20 — military fired on protesters. SWAT replaced SARS (widely seen as rebrand). Consciousness permanently shifted.","benjamin":"Sustained documentation over 3 years created a trigger-ready infrastructure — the video was the match in a room full of gas.","outcome_score":2,"funders":["Diaspora crowdfunding","Feminist Coalition Nigeria"],"orgs":["Feminist Coalition","Enough is Enough Nigeria"],"timeline":[{"year":2017,"type":"BUILDUP","event":"#EndSARS hashtag begins"},{"year":2020,"type":"TIP","event":"Video goes viral"},{"year":2020,"type":"SETBACK","event":"Lekki massacre"}]},
  {"id":9,"name":"India Farmers' Protest","region":"India","year":2020,"failed":false,"issue":"Three Farm Acts deregulating agricultural markets, threatening 250 million farmers.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":3,"trigger":4,"total":22},"tags":["participatory-structure","identity-threat","infrastructure-determines-magnitude"],"trigger":"November 26, 2020 'Dilli Chalo' march to Delhi. Police met farmers with tear gas and water cannons in winter.","outcome":"November 19, 2021: PM Modi announced repeal of all three Farm Acts. Unprecedented reversal. One of most significant government capitulations in Indian democratic history.","benjamin":"Staying power matters — the farmers won through 13 months of sustained, disciplined presence, not through spectacle.","outcome_score":5,"funders":["Punjab farmer unions","Diaspora support"],"orgs":["Samyukta Kisan Morcha","BKU (Bharatiya Kisan Union)"],"timeline":[{"year":2020,"type":"BUILDUP","event":"Farm Acts passed without consultation"},{"year":2020,"type":"TIP","event":"Dilli Chalo march"},{"year":2021,"type":"WIN","event":"Modi repeals all three acts"}]},
  {"id":10,"name":"South Korea Candlelight Revolution","region":"South Korea","year":2016,"failed":false,"issue":"President Park Geun-hye's corruption and influence by cult figure Choi Soon-sil.","scores":{"grievance":5,"narrative":5,"infrastructure":4,"permission":4,"trigger":5,"total":23},"tags":["institutional-trigger","participatory-structure","manufactured-permission"],"trigger":"October 2016: revelations that Park shared classified documents with Choi Soon-sil, a shamanistic cult leader.","outcome":"Park impeached Dec 2016. Constitutional Court upheld March 2017. Arrested and convicted 2018. Moon Jae-in elected. Democracy functioned.","benjamin":"The visual aesthetic of the movement (candles, peacefulness, beauty) was a strategic choice that made it impossible to delegitimize.","outcome_score":5,"funders":["Korean civil society"],"orgs":["Citizens' Coalition for Economic Justice","People's Solidarity for Participatory Democracy"],"timeline":[{"year":2016,"type":"TIP","event":"Corruption revealed"},{"year":2016,"type":"WIN","event":"Park impeached"},{"year":2017,"type":"WIN","event":"Constitutional Court upholds"}]},
  {"id":11,"name":"Argentina Green Wave / Abortion Rights","region":"Argentina/Latin America","year":2020,"failed":false,"issue":"Legalization of abortion in Argentina.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":4,"trigger":4,"total":23},"tags":["cross-border-contagion","deliberate-engineering","visual-simplification"],"trigger":"December 30, 2020: Argentine Congress passed Voluntary Interruption of Pregnancy Law at 4am after years of organizing.","outcome":"Abortion legal up to 14 weeks. Ripple effect: Mexico Supreme Court 2021, Colombia 2022. Green wave transformed regional landscape.","benjamin":"The green handkerchief is a masterclass in visual movement identity — a single wearable object that creates instant identification and is maximally replicable.","outcome_score":5,"funders":["Latin American feminist funds","OSF"],"orgs":["Campaña Nacional por el Derecho al Aborto","Católicas por el Derecho a Decidir"],"timeline":[{"year":2018,"type":"BUILDUP","event":"First Congress vote fails narrowly"},{"year":2020,"type":"WIN","event":"Law passes"}]},
  {"id":12,"name":"NiUnaMenos — Anti-Femicide","region":"Argentina/Global","year":2015,"failed":false,"issue":"Epidemic of femicide treated as private tragedy rather than systemic violence.","scores":{"grievance":5,"narrative":5,"infrastructure":4,"permission":4,"trigger":5,"total":23},"tags":["visual-simplification","participatory-structure","cross-border-contagion"],"trigger":"May 2015: Murder of 14-year-old Chiara Páez, found pregnant and buried under boyfriend's home.","outcome":"300,000+ first march Buenos Aires. Spread to 80 countries. Legislative strengthening of femicide laws. Became foundation for Green Wave.","benjamin":"Three words ('Not One Less') became a global movement. Visual and verbal simplicity is not compromise — it's power.","outcome_score":4,"funders":["Argentine feminist collectives"],"orgs":["NiUnaMenos collective","Feminist networks"],"timeline":[{"year":2015,"type":"TIP","event":"Chiara Páez murder"},{"year":2015,"type":"WIN","event":"300K march"}]},
  {"id":13,"name":"Rana Plaza Aftermath","region":"Bangladesh/Global","year":2013,"failed":false,"issue":"Garment factory collapse killing 1,138 workers; supply chain accountability.","scores":{"grievance":5,"narrative":5,"infrastructure":3,"permission":4,"trigger":5,"total":22},"tags":["supply-chain-accountability","visual-simplification","institutional-trigger"],"trigger":"April 24, 2013: Rana Plaza collapse. Workers forced back to work in building with visible structural cracks. 1,138 dead.","outcome":"Bangladesh Accord on Fire and Building Safety — first legally binding supply chain safety agreement. 56,000+ inspections. Model for fashion accountability.","benjamin":"The 'forced back to work' detail made it murder, not accident. Labels in rubble connected abstract supply chains to specific brands.","outcome_score":4,"funders":["IndustriALL Global Union","Clean Clothes Campaign"],"orgs":["Bangladesh Accord","Clean Clothes Campaign","Fashion Revolution"],"timeline":[{"year":2013,"type":"TIP","event":"Building collapse"},{"year":2013,"type":"WIN","event":"Bangladesh Accord signed"}]},
  {"id":14,"name":"Hong Kong Umbrella Movement","region":"Hong Kong","year":2014,"failed":true,"issue":"Beijing withdrawing promise of genuine universal suffrage.","scores":{"grievance":5,"narrative":4,"infrastructure":4,"permission":3,"trigger":4,"total":20},"tags":["failed-tip","institutional-intransigence","visual-symbol"],"trigger":"September 28, 2014: tear gas fired on protesters — activists opened umbrellas as protection, creating iconic visual.","outcome":"[FAILED TIP] Occupation lasted 79 days. Beijing made no concessions. BUT: planted conditions for 2019 uprising.","benjamin":"Some campaigns are the 2014 to another campaign's 2020. Document carefully — the seeds are the win, even when immediate outcome fails.","outcome_score":1,"funders":["Hong Kong civil society"],"orgs":["Occupy Central","Student federations"],"timeline":[{"year":2014,"type":"TIP","event":"Umbrella protests begin"},{"year":2014,"type":"SETBACK","event":"No concessions"}]},
  {"id":15,"name":"Hong Kong 2019-2020 Protests","region":"Hong Kong","year":2019,"failed":true,"issue":"Extradition bill allowing transfer to mainland China; broader democracy demands.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":3,"trigger":5,"total":23},"tags":["failed-tip","authoritarian-absorption","external-leverage-gap"],"trigger":"Extradition bill 2019. 2 million out of 7.4 million Hong Kongers marched June 16, 2019.","outcome":"[FAILED TIP] Extradition bill withdrawn. BUT: National Security Law 2020 crushed movement. Most leaders arrested. Democracy gutted.","benjamin":"When opponent controls unlimited force without external accountability, all five conditions can be maxed and still fail. External leverage is the sixth condition for authoritarian contexts.","outcome_score":1,"funders":["Hong Kong democracy supporters"],"orgs":["Civil Human Rights Front","Demosistō"],"timeline":[{"year":2019,"type":"TIP","event":"2 million march"},{"year":2019,"type":"PARTIAL-WIN","event":"Extradition bill withdrawn"},{"year":2020,"type":"SUPPRESSED","event":"National Security Law imposed"}]},
  {"id":16,"name":"Sudan Revolution 2018-2019","region":"Sudan","year":2019,"failed":false,"issue":"30-year rule of Omar al-Bashir, economic collapse, bread price increases.","scores":{"grievance":5,"narrative":4,"infrastructure":4,"permission":3,"trigger":4,"total":20},"tags":["female-leadership-visual","economic-trigger","military-absorption"],"trigger":"December 19, 2018 protests after bread price tripled. Alaa Salah's 'woman in white' photo became global icon.","outcome":"Al-Bashir removed April 2019. Transitional government. BUT: military coup October 2021 ended civilian transition. Civil war by 2023.","benjamin":"Alaa Salah's image shows how a single person becomes the visual embodiment of millions. The most powerful images are of people, not just problems.","outcome_score":2,"funders":["Sudanese diaspora"],"orgs":["Sudanese Professionals Association","Resistance Committees"],"timeline":[{"year":2018,"type":"TIP","event":"Bread protests begin"},{"year":2019,"type":"WIN","event":"Bashir removed"},{"year":2021,"type":"REVERSAL","event":"Military coup"},{"year":2023,"type":"SETBACK","event":"Civil war begins"}]},
  {"id":17,"name":"Tunisia Jasmine Revolution","region":"Tunisia","year":2011,"failed":false,"issue":"Ben Ali authoritarian regime, unemployment, corruption.","scores":{"grievance":5,"narrative":4,"infrastructure":4,"permission":3,"trigger":5,"total":21},"tags":["martyrdom-trigger","military-refusal","institutional-civil-society"],"trigger":"December 17, 2010: Mohamed Bouazizi self-immolation after police confiscated his fruit cart and humiliated him.","outcome":"Ben Ali fled January 14, 2011 after 23 years. First successful Arab Spring. New constitution 2014. Nobel Peace Prize 2015. (Kais Saied coup 2021 partially reversed gains.)","benjamin":"Bouazizi is the straw turtle of the Arab Spring — one specific, undeniable human story that crystallized decades of grievance into ignition.","outcome_score":4,"funders":["UGTT labor union"],"orgs":["UGTT","Tunisian Human Rights League"],"timeline":[{"year":2010,"type":"TIP","event":"Bouazizi self-immolation"},{"year":2011,"type":"WIN","event":"Ben Ali flees"},{"year":2014,"type":"WIN","event":"New constitution"},{"year":2021,"type":"SETBACK","event":"Saied power grab"}]},
  {"id":18,"name":"Egypt Arab Spring","region":"Egypt","year":2011,"failed":true,"issue":"Mubarak's 30-year rule, economic exclusion, police brutality.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":3,"trigger":5,"total":20},"tags":["failed-tip","infrastructure-gap","military-absorption"],"trigger":"Tahrir Square demonstrations began January 25, 2011, inspired by Tunisia.","outcome":"[FAILED TIP] Mubarak fell Feb 11. Muslim Brotherhood won elections 2012. Military coup 2013. Sisi government more authoritarian than Mubarak.","benjamin":"High grievance, strong trigger, weak organizational infrastructure = brief tip that collapses. Infrastructure determines what happens AFTER the tip.","outcome_score":1,"funders":["Egyptian civil society"],"orgs":["April 6 Youth Movement","Kefaya"],"timeline":[{"year":2011,"type":"TIP","event":"Tahrir occupation"},{"year":2011,"type":"WIN","event":"Mubarak falls"},{"year":2013,"type":"REVERSAL","event":"Military coup"}]},
  {"id":19,"name":"Extinction Rebellion","region":"UK/Global","year":2018,"failed":false,"issue":"Government inaction on climate; demand for net zero by 2025, Citizens' Assembly.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":3,"trigger":4,"total":19},"tags":["manufactured-trigger","self-created-permission","organizational-burnout"],"trigger":"Declaration of Rebellion, Parliament Square, London, October 31, 2018.","outcome":"UK Parliament declared climate emergency. Major 2019 disruptions. Then XR fragmented — internal tensions between disruption and winnable demands.","benjamin":"Internal triggers burn faster than external triggers. Disruption without clear winnable demands produces energy without legacy.","outcome_score":3,"funders":["Climate Emergency Fund","Individual donors"],"orgs":["Extinction Rebellion","Just Stop Oil"],"timeline":[{"year":2018,"type":"TIP","event":"Declaration of Rebellion"},{"year":2019,"type":"WIN","event":"UK climate emergency declared"},{"year":2020,"type":"SETBACK","event":"Movement fragmentation"}]},
  {"id":20,"name":"Montreal Protocol","region":"Global","year":1987,"failed":false,"issue":"Ozone-depleting CFCs destroying stratospheric ozone layer.","scores":{"grievance":4,"narrative":5,"infrastructure":4,"permission":4,"trigger":5,"total":22},"tags":["industrial-pivot","satellite-evidence","universal-ratification"],"trigger":"1985 British Antarctic Survey discovers Antarctic ozone hole — larger than any model predicted.","outcome":"Montreal Protocol signed 1987. 198 parties — universal ratification. Ozone hole slowly closing. Most successful environmental treaty in history.","benjamin":"The most successful environmental treaty worked because: visible harm, alternative technology existed, industry switched sides. All three conditions matter.","outcome_score":5,"funders":["UNEP","National governments"],"orgs":["UNEP","National ozone units"],"timeline":[{"year":1985,"type":"TIP","event":"Ozone hole discovered"},{"year":1987,"type":"WIN","event":"Montreal Protocol signed"},{"year":2023,"type":"CONSOLIDATION","event":"Ozone recovery on track"}]},
  {"id":21,"name":"Ottawa Treaty / Landmine Ban","region":"Global","year":1997,"failed":false,"issue":"Anti-personnel landmines killing and maiming civilians in post-conflict countries.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":4,"trigger":4,"total":23},"tags":["NGO-led-treaty","celebrity-amplifier","bypass-veto-structures"],"trigger":"Canadian Foreign Minister Lloyd Axworthy's October 1996 challenge: negotiate complete ban in one year, outside UN.","outcome":"122 countries signed Dec 1997. Nobel Peace Prize. Mine production virtually eliminated. Casualties dropped from 26,000/year to under 5,000.","benjamin":"Civil society CAN write treaties. The ICBL created a treaty outside normal diplomatic channels — model for plastics treaty efforts.","outcome_score":5,"funders":["International donors","Nobel Prize money"],"orgs":["ICBL","Human Rights Watch","Handicap International"],"timeline":[{"year":1992,"type":"BUILDUP","event":"ICBL founded"},{"year":1997,"type":"WIN","event":"Ottawa Treaty signed"}]},
  {"id":22,"name":"Paris Climate Agreement","region":"Global","year":2015,"failed":false,"issue":"Global greenhouse gas emissions causing catastrophic climate change.","scores":{"grievance":4,"narrative":4,"infrastructure":5,"permission":4,"trigger":4,"total":21},"tags":["failure-as-precondition","bilateral-enabling-multilateral","institutional-innovation"],"trigger":"French diplomatic process 2015 — COP21, following China-US bilateral deal November 2014.","outcome":"196 parties signed. First universal climate agreement. 1.5°C target. Now under threat — Trump withdrawal, fossil fuel pushback.","benjamin":"Copenhagen's collapse in 2009 made Paris possible in 2015. Failure builds conditions for later success.","outcome_score":4,"funders":["National governments","Green Climate Fund"],"orgs":["UNFCCC","Climate Action Network"],"timeline":[{"year":2009,"type":"SETBACK","event":"Copenhagen collapse"},{"year":2015,"type":"WIN","event":"Paris Agreement signed"},{"year":2017,"type":"SETBACK","event":"Trump announces withdrawal"}]},
  {"id":23,"name":"Fossil Fuel Divestment","region":"Global","year":2012,"failed":false,"issue":"Institutional investment providing social license to fossil fuel companies.","scores":{"grievance":4,"narrative":5,"infrastructure":5,"permission":4,"trigger":4,"total":22},"tags":["model-replication","financial-moral-fusion","institutional-cascade"],"trigger":"350.org launched 'Go Fossil Free' 2012. Rockefeller Brothers Fund divestment 2014 — heirs to oil fortune divesting.","outcome":"$40.5 trillion in assets committed to divestment by 2023. Harvard $53B endowment divested 2021. Social license erosion visible.","benjamin":"The 'stranded assets' financial argument joined the moral argument — made divestment rational, not just ethical.","outcome_score":4,"funders":["350.org donors","Climate Emergency Fund"],"orgs":["350.org","Divest-Invest Network"],"timeline":[{"year":2012,"type":"BUILDUP","event":"Go Fossil Free launched"},{"year":2014,"type":"TIP","event":"Rockefeller Brothers Fund divests"},{"year":2021,"type":"WIN","event":"Harvard divests"}]},
  {"id":24,"name":"ACT UP / AIDS Treatment Access","region":"United States/Global","year":1987,"failed":false,"issue":"AIDS epidemic killing thousands while FDA blocked treatments; Reagan's silence.","scores":{"grievance":5,"narrative":5,"infrastructure":4,"permission":2,"trigger":5,"total":21},"tags":["direct-action-science","visual-confrontation","parallel-expertise"],"trigger":"ACT UP founded March 1987. First demonstration on Wall Street targeting AZT pricing.","outcome":"FDA accelerated drug approval. AZT price forced down 20%. Protease inhibitors approved in record time. Template for patient advocacy.","benjamin":"'Silence = Death' is one of most effective activist visuals in history — three words, a symbol, and an accusation.","outcome_score":4,"funders":["Individual donors","LGBTQ foundations"],"orgs":["ACT UP","amfAR","Gay Men's Health Crisis"],"timeline":[{"year":1987,"type":"TIP","event":"ACT UP founded"},{"year":1989,"type":"WIN","event":"FDA parallel track created"}]},
  {"id":25,"name":"Urgenda Climate Case","region":"Netherlands","year":2019,"failed":false,"issue":"Dutch government failing to meet its own climate commitments.","scores":{"grievance":4,"narrative":4,"infrastructure":4,"permission":4,"trigger":4,"total":20},"tags":["legal-landmark","global-cascade","human-rights-framing"],"trigger":"Dutch Supreme Court ruling December 20, 2019 — government must cut emissions 25% by end of 2020.","outcome":"First climate case to reach supreme court and win. Created global template. Climate litigation boom — 1,800+ cases by 2023.","benjamin":"Art that makes climate harm visceral and specific helps lawyers demonstrate 'concrete harm' — Benjamin's work IS legal evidence.","outcome_score":4,"funders":["Urgenda Foundation donors"],"orgs":["Urgenda Foundation","ClientEarth"],"timeline":[{"year":2013,"type":"BUILDUP","event":"Case filed"},{"year":2019,"type":"WIN","event":"Supreme Court rules for plaintiffs"}]},
  {"id":26,"name":"SOPA/PIPA Defeat","region":"United States","year":2012,"failed":false,"issue":"Legislation enabling broad internet censorship under copyright enforcement.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":4,"trigger":5,"total":24},"tags":["manufactured-trigger","fire-alarm-model","institutional-moment"],"trigger":"January 18, 2012: Wikipedia, Reddit, Google, Mozilla coordinated internet blackout.","outcome":"Both bills killed. 80 Senate co-sponsors to zero in 12 days. Created precedent for coordinated tech-sector civil disobedience.","benjamin":"Campaigns can tip AGAINST an undesirable future — 'Stop X' campaigns are powerful when threat is made visceral.","outcome_score":5,"funders":["EFF","Tech companies"],"orgs":["EFF","Fight for the Future","Wikipedia"],"timeline":[{"year":2012,"type":"TIP","event":"Internet blackout"},{"year":2012,"type":"WIN","event":"Bills killed"}]},
  {"id":27,"name":"Fees Must Fall","region":"South Africa","year":2015,"failed":false,"issue":"University fee increases excluding poor students; curriculum decolonization.","scores":{"grievance":5,"narrative":5,"infrastructure":4,"permission":3,"trigger":5,"total":22},"tags":["institutional-trigger","cross-campus-contagion","economic-justice"],"trigger":"October 2015: Wits University announced 10.5% fee increase. National strike spread to all major universities within days.","outcome":"Zuma announced 0% fee increase for 2016. Free higher education for households under R350,000 announced 2017. Curriculum decolonization ongoing.","benjamin":"The fee announcement was the trigger — not underlying inequality. Wait for the institutional moment that makes abstract grievance concrete.","outcome_score":4,"funders":["South African student organizations"],"orgs":["Student Representative Councils","Rhodes Must Fall"],"timeline":[{"year":2015,"type":"TIP","event":"Fee increase announced"},{"year":2015,"type":"WIN","event":"0% increase"},{"year":2017,"type":"WIN","event":"Free higher education announced"}]},
  {"id":28,"name":"Ireland Repeal the 8th","region":"Ireland","year":2018,"failed":false,"issue":"Constitutional Eighth Amendment banning abortion.","scores":{"grievance":4,"narrative":5,"infrastructure":5,"permission":4,"trigger":5,"total":23},"tags":["citizens-assembly-permission","prior-infrastructure-redeployed","martyrdom-trigger"],"trigger":"Savita Halappanavar death 2012 + Citizens' Assembly 2016-2017 recommendation.","outcome":"May 25, 2018 referendum — 66.4% YES. Eighth Amendment repealed. Template for deliberative democracy.","benjamin":"Citizens' Assemblies build permission structures that make previously impossible outcomes achievable. The mechanism matters as much as message.","outcome_score":5,"funders":["Together for Yes donors","Atlantic Philanthropies"],"orgs":["Together for Yes","Amnesty Ireland","NWCI"],"timeline":[{"year":2012,"type":"BUILDUP","event":"Savita Halappanavar death"},{"year":2018,"type":"WIN","event":"66.4% vote to repeal"}]},
  {"id":29,"name":"Wangari Maathai / Green Belt","region":"Kenya","year":2004,"failed":false,"issue":"Deforestation, soil erosion, women's disempowerment.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":2,"trigger":3,"total":20},"tags":["deliberate-long-game","participatory-structure","institutional-recognition"],"trigger":"No single trigger — Nobel Peace Prize 2004 created global visibility for 27 years of work.","outcome":"51 million trees planted by 2004. Women's empowerment serving hundreds of thousands. Model adopted in 30+ African countries.","benjamin":"Long-game visual work (51 million trees = visual proof of possibility) creates its own tipping through accumulated scale.","outcome_score":5,"funders":["UNEP","Various foundations"],"orgs":["Green Belt Movement"],"timeline":[{"year":1977,"type":"BUILDUP","event":"Green Belt Movement founded"},{"year":2004,"type":"WIN","event":"Nobel Peace Prize"}]},
  {"id":30,"name":"Jubilee 2000 / Debt Cancellation","region":"Global","year":2000,"failed":false,"issue":"Unpayable debts crushing Global South countries.","scores":{"grievance":5,"narrative":4,"infrastructure":4,"permission":3,"trigger":4,"total":20},"tags":["celebrity-amplifier","religious-moral-framing","specific-financial-ask"],"trigger":"G8 Summit Birmingham 1998 — 70,000 formed human chain. Bono and Bob Geldof mobilized.","outcome":"$100 billion in debt cancelled for 42 countries by 2005. Freed billions for health and education.","benjamin":"Celebrity amplification works when tied to specific demands — Bono didn't just raise awareness, he met finance ministers. Visual spectacle + policy-specific asks.","outcome_score":4,"funders":["Oxfam","Christian Aid","CAFOD"],"orgs":["Jubilee 2000 Coalition","Drop the Debt"],"timeline":[{"year":1998,"type":"TIP","event":"Birmingham human chain"},{"year":2005,"type":"WIN","event":"$100B cancelled"}]},
  {"id":31,"name":"Myanmar Coup Resistance","region":"Myanmar","year":2021,"failed":true,"issue":"Military coup against elected government February 1, 2021.","scores":{"grievance":5,"narrative":4,"infrastructure":3,"permission":2,"trigger":5,"total":19},"tags":["failed-tip","military-force","external-leverage-gap"],"trigger":"February 1, 2021 coup arrest of Aung San Suu Kyi and elected officials.","outcome":"[FAILED TIP] Military retained power despite widespread resistance. 3,000+ killed. Junta conducting aerial bombardments on civilians.","benjamin":"Another case where five conditions are met but authoritarian force + external indifference produces tragedy. External leverage is critical.","outcome_score":0,"funders":["Diaspora support","International emergency funds"],"orgs":["Civil Disobedience Movement","NUG (National Unity Government)"],"timeline":[{"year":2021,"type":"TIP","event":"Coup and resistance"},{"year":2021,"type":"SUPPRESSED","event":"Violent crackdown"}]},
  {"id":32,"name":"New Zealand Zero Carbon Act","region":"New Zealand","year":2019,"failed":false,"issue":"Climate policy requiring binding emissions reductions.","scores":{"grievance":4,"narrative":4,"infrastructure":4,"permission":5,"trigger":4,"total":21},"tags":["institutional-design","durable-policy","bipartisan-support"],"trigger":"Climate Change Response (Zero Carbon) Amendment Act passed November 2019 with near-unanimous parliamentary support.","outcome":"Net zero by 2050 legally binding. Independent Climate Change Commission. Survived government change to National Party 2023.","benjamin":"The Zero Carbon Act's durability came from deliberate institutional design: independent commission, legally binding budgets. Build things designed to outlast activists.","outcome_score":5,"funders":["New Zealand government","Philanthropic foundations"],"orgs":["Generation Zero","WWF-NZ"],"timeline":[{"year":2019,"type":"WIN","event":"Zero Carbon Act passed"},{"year":2023,"type":"CONSOLIDATION","event":"Survives government change"}]},
  {"id":33,"name":"Snowden / Digital Rights","region":"Global","year":2013,"failed":false,"issue":"NSA/GCHQ mass surveillance collecting data on hundreds of millions without consent.","scores":{"grievance":4,"narrative":4,"infrastructure":3,"permission":3,"trigger":5,"total":19},"tags":["documentation-cascade","incremental-revelation","technical-enabling-advocacy"],"trigger":"June 5, 2013: Glenn Greenwald and Laura Poitras publish first NSA PRISM documents.","outcome":"USA FREEDOM Act 2015. EU Privacy Shield invalidated. Mass adoption of end-to-end encryption. GDPR partly driven by post-Snowden anxieties.","benjamin":"Sequential revelation — each new document more damning — maintains attention. Campaign cadence matters.","outcome_score":3,"funders":["First Look Media","Freedom of the Press Foundation"],"orgs":["EFF","ACLU","Privacy International"],"timeline":[{"year":2013,"type":"TIP","event":"Snowden revelations begin"},{"year":2015,"type":"WIN","event":"USA FREEDOM Act"}]},
  {"id":34,"name":"South Korea 2024 Martial Law Reversal","region":"South Korea","year":2024,"failed":false,"issue":"President Yoon Suk-yeol declared martial law December 3, 2024.","scores":{"grievance":5,"narrative":5,"infrastructure":5,"permission":4,"trigger":5,"total":24},"tags":["institutional-trigger","elite-fragmentation","military-restraint"],"trigger":"December 3, 2024: Yoon declares martial law. National Assembly members physically fought through military cordons to vote.","outcome":"Martial law lifted within 6 hours by National Assembly vote. Yoon impeached December 14, 2024. Democracy held.","benjamin":"South Korea's democratic institutions WORKED. The story of institutions holding against authoritarianism is the most important counter-narrative.","outcome_score":5,"funders":["Korean civil society"],"orgs":["National Assembly opposition","Constitutional Court"],"timeline":[{"year":2024,"type":"TIP","event":"Martial law declared"},{"year":2024,"type":"WIN","event":"Martial law reversed in 6 hours"},{"year":2024,"type":"WIN","event":"Yoon impeached"}]},
