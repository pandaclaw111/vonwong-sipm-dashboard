<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>SIPM — Social Inflection Point Monitor</title>
<script src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #08090c;
  --surface: #0f1117;
  --surface2: #161922;
  --surface3: #1e222f;
  --accent: #00d4aa;
  --accent2: #ff6b6b;
  --accent3: #ffd93d;
  --accent4: #6c5ce7;
  --text: #e8eaf0;
  --text-muted: #6b7394;
  --border: #252a3a;
  --success: #00d4aa;
  --warning: #ffd93d;
  --danger: #ff6b6b;
  --radius: 10px;
  --font: 'Inter', system-ui, -apple-system, sans-serif;
  
  /* Category colors */
  --cat-climate: #00c8a0;
  --cat-democracy: #f59e0b;
  --cat-labor: #ef4444;
  --cat-health: #8b5cf6;
  --cat-digital: #3b82f6;
  --cat-indigenous: #f97316;
  --cat-other: #6b7280;
  
  /* Edge type colors */
  --edge-compound: #ff7b54;
  --edge-actors: #4a9eff;
  --edge-narrative: #4ade80;
  --edge-geographic: #fbbf24;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; overflow-x: hidden; }
body { 
  background: var(--bg); 
  color: var(--text); 
  font-family: var(--font); 
  font-size: 14px; 
  line-height: 1.6; 
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

/* Touch/click improvements */
button, .case-card, .calendar-event, .domain-card, .funder-card, .candidate-card, .nav-tab, .filter-btn, .page-btn, .eco-tab-btn, .network-filter-btn, .org-item a, .funder-name a, .legend-filter-item {
  -webkit-tap-highlight-color: rgba(0,212,170,0.2);
  touch-action: manipulation;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(8,9,12,0.92); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 2px;
  padding: 0 16px; height: 52px;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
}
nav::-webkit-scrollbar { display: none; }
.nav-logo { 
  font-weight: 900; font-size: 15px; 
  background: linear-gradient(135deg, var(--accent), #00f5c4);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; letter-spacing: -0.5px; 
  margin-right: 8px; white-space: nowrap; flex-shrink: 0; 
}
.nav-logo span { color: var(--text-muted); font-weight: 400; -webkit-text-fill-color: var(--text-muted); }
.nav-tab { 
  background: none; border: none; color: var(--text-muted); 
  padding: 8px 12px; border-radius: 8px; cursor: pointer; 
  font-size: 12px; font-weight: 600; transition: all 0.2s; 
  white-space: nowrap; flex-shrink: 0;
  min-height: 44px; min-width: 44px;
  display: flex; align-items: center; justify-content: center;
}
.nav-tab:hover { color: var(--text); background: var(--surface2); }
.nav-tab.active { color: var(--accent); background: rgba(0,212,170,0.1); }
.nav-tab:active { transform: scale(0.95); }
.nav-right { margin-left: auto; display: flex; gap: 6px; align-items: center; flex-shrink: 0; }
.badge-count { 
  background: linear-gradient(135deg, var(--accent), #00f5c4); 
  color: #000; border-radius: 16px; padding: 3px 10px; 
  font-size: 10px; font-weight: 800; 
}
.last-updated { font-size: 10px; color: var(--text-muted); white-space: nowrap; }

/* LAYOUT */
.page { display: none; padding: 64px 16px 80px; max-width: 1440px; margin: 0 auto; overflow-x: hidden; width: 100%; }
.page.active { display: block; }
@media (min-width: 768px) { .page { padding: 72px 24px 60px; } }

/* STATS */
.stats-grid { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 10px; margin-bottom: 20px; 
}
@media (min-width: 600px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }
@media (min-width: 1000px) { .stats-grid { grid-template-columns: repeat(6, 1fr); } }
.stat-card { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: var(--radius); padding: 14px; 
  transition: all 0.2s; 
}
.stat-card:hover { border-color: var(--accent); transform: translateY(-1px); }
.stat-card .val { font-size: 28px; font-weight: 900; line-height: 1; margin-bottom: 2px; }
.stat-card .lbl { color: var(--text-muted); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.stat-card .sub { color: var(--text-muted); font-size: 10px; margin-top: 2px; }

/* GRID LAYOUTS */
.two-col { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 14px; }
@media (min-width: 900px) { .two-col { grid-template-columns: 1fr 1fr; } }
.three-col { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 14px; }
@media (min-width: 800px) { .three-col { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1100px) { .three-col { grid-template-columns: repeat(3, 1fr); } }

/* CARD */
.card { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: var(--radius); padding: 16px; margin-bottom: 14px; 
}
.card-title { 
  font-size: 11px; font-weight: 700; text-transform: uppercase; 
  letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 12px; 
}
.chart-wrap { position: relative; height: 280px; }
.chart-wrap-sm { position: relative; height: 200px; }

/* NETWORK CONTAINER */
#network-container { 
  width: 100%; 
  height: 580px; 
  background: radial-gradient(ellipse at center, #0f1218 0%, #0a0a0f 100%);
  border-radius: var(--radius); 
  position: relative; 
  overflow: hidden;
  max-width: 100%;
}
#network-svg { 
  max-width: 100%; 
  display: block; 
  cursor: grab;
}
#network-svg:active { cursor: grabbing; }
@media (min-width: 768px) { #network-container { height: 680px; } }

/* NETWORK WRAPPER - Flex layout for legend sidebar on desktop */
.network-wrapper {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
@media (min-width: 1024px) {
  .network-wrapper {
    flex-direction: row;
  }
  #network-container {
    flex: 1;
    min-width: 0;
  }
}

/* INTERACTIVE LEGEND CONTROL PANEL */
.legend-panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  width: 100%;
  max-height: none;
  overflow-y: auto;
}
@media (min-width: 1024px) {
  .legend-panel {
    width: 280px;
    min-width: 280px;
    max-height: 680px;
    position: sticky;
    top: 72px;
  }
}

.legend-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
  cursor: pointer;
}
.legend-panel-title {
  font-size: 13px;
  font-weight: 800;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 6px;
}
.legend-toggle-btn {
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text-muted);
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.legend-toggle-btn:hover { background: var(--surface3); color: var(--text); }
@media (min-width: 1024px) {
  .legend-toggle-btn { display: none; }
}

.legend-panel-body {
  display: none;
}
.legend-panel-body.open {
  display: block;
}
@media (min-width: 1024px) {
  .legend-panel-body { display: block !important; }
}

.legend-section {
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.legend-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}
.legend-section-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

/* Filter items */
.legend-filter-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  margin: 2px 0;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 11px;
  user-select: none;
}
.legend-filter-item:hover {
  background: var(--surface2);
}
.legend-filter-item.active {
  background: rgba(0,212,170,0.12);
}
.legend-filter-item.dimmed {
  opacity: 0.4;
}
.legend-filter-item .indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
}
.legend-filter-item .indicator.line {
  width: 20px;
  height: 3px;
  border-radius: 2px;
}
.legend-filter-item .indicator.dashed {
  background: repeating-linear-gradient(90deg, var(--edge-compound), var(--edge-compound) 4px, transparent 4px, transparent 7px);
}
.legend-filter-item .indicator.dotted {
  background: repeating-linear-gradient(90deg, var(--edge-narrative), var(--edge-narrative) 2px, transparent 2px, transparent 5px);
}
.legend-filter-item .label {
  flex: 1;
  color: var(--text);
}
.legend-filter-item .count {
  font-size: 10px;
  color: var(--text-muted);
  font-weight: 600;
}
.legend-filter-item .checkbox {
  width: 14px;
  height: 14px;
  border: 1.5px solid var(--border);
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.legend-filter-item.active .checkbox {
  background: var(--accent);
  border-color: var(--accent);
}
.legend-filter-item.active .checkbox::after {
  content: '✓';
  color: #000;
  font-size: 10px;
  font-weight: 700;
}

/* Node size scale visual */
.node-size-scale {
  display: flex;
  align-items: flex-end;
  gap: 12px;
  padding: 8px 0;
}
.node-size-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  padding: 4px;
  border-radius: 6px;
  transition: all 0.15s;
}
.node-size-item:hover {
  background: var(--surface2);
}
.node-size-item.active {
  background: rgba(0,212,170,0.12);
}
.node-size-item .node-circle {
  border-radius: 50%;
  background: var(--accent);
  opacity: 0.7;
}
.node-size-item .node-label {
  font-size: 9px;
  color: var(--text-muted);
  text-align: center;
}
.node-size-item .node-range {
  font-size: 8px;
  color: var(--text-muted);
}

/* Benjamin's Lens toggle */
.benjamin-lens-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  background: linear-gradient(135deg, rgba(0,212,170,0.08), rgba(0,245,196,0.04));
  border: 1px solid rgba(0,212,170,0.25);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
}
.benjamin-lens-toggle:hover {
  border-color: var(--accent);
}
.benjamin-lens-toggle.active {
  background: linear-gradient(135deg, rgba(0,212,170,0.2), rgba(0,245,196,0.1));
  border-color: var(--accent);
}
.benjamin-lens-toggle .toggle-switch {
  width: 36px;
  height: 20px;
  background: var(--surface3);
  border-radius: 10px;
  position: relative;
  transition: all 0.2s;
}
.benjamin-lens-toggle .toggle-switch::after {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  background: var(--text-muted);
  border-radius: 50%;
  top: 2px;
  left: 2px;
  transition: all 0.2s;
}
.benjamin-lens-toggle.active .toggle-switch {
  background: var(--accent);
}
.benjamin-lens-toggle.active .toggle-switch::after {
  left: 18px;
  background: #000;
}
.benjamin-lens-toggle .toggle-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text);
  flex: 1;
}
.benjamin-lens-toggle .toggle-icon {
  font-size: 14px;
}

/* Reset filters button */
.reset-filters-btn {
  width: 100%;
  padding: 10px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  margin-top: 8px;
}
.reset-filters-btn:hover {
  background: var(--surface3);
  color: var(--text);
}

/* Category filter buttons (top of network) */
.network-filters {
  position: absolute; top: 12px; left: 12px; right: 12px;
  display: flex; gap: 6px; flex-wrap: wrap; z-index: 10;
}
@media (min-width: 1024px) {
  .network-filters { display: none; }
}
.network-filter-btn {
  background: rgba(8,9,12,0.88); border: 1px solid var(--border);
  color: var(--text-muted); padding: 8px 12px; border-radius: 6px;
  cursor: pointer; font-size: 10px; font-weight: 600; transition: all 0.15s;
  min-height: 36px; min-width: 36px;
  backdrop-filter: blur(8px);
}
.network-filter-btn:hover { border-color: var(--accent); color: var(--text); }
.network-filter-btn.active { background: var(--accent); border-color: var(--accent); color: #000; }
.network-filter-btn:active { transform: scale(0.92); }
.network-filter-btn[data-cat="Climate"].active { background: var(--cat-climate); border-color: var(--cat-climate); }
.network-filter-btn[data-cat="Democracy"].active { background: var(--cat-democracy); border-color: var(--cat-democracy); }
.network-filter-btn[data-cat="Labor"].active { background: var(--cat-labor); border-color: var(--cat-labor); }
.network-filter-btn[data-cat="Health"].active { background: var(--cat-health); border-color: var(--cat-health); }
.network-filter-btn[data-cat="Digital"].active { background: var(--cat-digital); border-color: var(--cat-digital); }
.network-filter-btn[data-cat="Indigenous"].active { background: var(--cat-indigenous); border-color: var(--cat-indigenous); }

/* Enhanced tooltip */
.network-tooltip {
  position: fixed; pointer-events: none; 
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 10px; padding: 14px 16px; font-size: 11px;
  max-width: 300px; opacity: 0; transition: opacity 0.15s;
  box-shadow: 0 12px 40px rgba(0,0,0,0.5); z-index: 1000;
  backdrop-filter: blur(12px);
}
.network-tooltip.visible { opacity: 1; }
.network-tooltip .tt-name { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
.network-tooltip .tt-cat { font-size: 10px; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
.network-tooltip .tt-score { 
  font-size: 12px; margin-bottom: 4px; 
  display: flex; align-items: center; gap: 8px;
}
.network-tooltip .tt-score .trajectory {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  font-weight: 600;
}
.network-tooltip .tt-score .trajectory.tipping { background: rgba(255,107,107,0.2); color: var(--danger); }
.network-tooltip .tt-score .trajectory.building { background: rgba(255,217,61,0.2); color: var(--warning); }
.network-tooltip .tt-score .trajectory.early { background: rgba(0,212,170,0.2); color: var(--accent); }
.network-tooltip .tt-desc { font-size: 10px; color: var(--text-muted); margin-top: 6px; line-height: 1.5; }
.network-tooltip .tt-connections { 
  font-size: 10px; color: var(--text-muted); margin-top: 8px; 
  padding-top: 8px; border-top: 1px solid var(--border); 
}
.network-tooltip .tt-connection-item {
  display: flex; align-items: center; gap: 6px;
  padding: 2px 0;
}
.network-tooltip .tt-connection-item .edge-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.network-tooltip .tt-tap-hint {
  font-size: 9px;
  color: var(--accent);
  margin-top: 6px;
  font-weight: 600;
}

/* Mobile filter button */
.mobile-filter-btn {
  display: none;
  position: absolute;
  bottom: 12px;
  left: 12px;
  background: var(--accent);
  border: none;
  color: #000;
  padding: 10px 16px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  z-index: 10;
  box-shadow: 0 4px 12px rgba(0,212,170,0.3);
}
@media (max-width: 1023px) {
  .mobile-filter-btn { display: block; }
}

/* Mobile hint */
.mobile-hint {
  display: none;
  position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%);
  background: rgba(0,212,170,0.15); border: 1px solid var(--accent);
  border-radius: 20px; padding: 8px 16px; font-size: 10px; color: var(--accent);
  z-index: 10; white-space: nowrap;
}
@media (max-width: 767px) {
  .mobile-hint { display: block; }
}

/* FILTERS */
.filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; align-items: center; }
.filter-btn { 
  background: var(--surface); border: 1px solid var(--border); 
  color: var(--text-muted); padding: 8px 14px; border-radius: 8px; 
  cursor: pointer; font-size: 11px; font-weight: 600; transition: all 0.15s;
  min-height: 44px; min-width: 44px;
  display: inline-flex; align-items: center; justify-content: center;
}
.filter-btn:hover { border-color: var(--accent); color: var(--text); }
.filter-btn.active { background: var(--accent); border-color: var(--accent); color: #000; }
.filter-btn:active { transform: scale(0.95); }
input[type=search], select { 
  background: var(--surface); border: 1px solid var(--border); 
  color: var(--text); padding: 8px 12px; border-radius: 8px; 
  font-size: 12px; outline: none; transition: border-color 0.2s; 
  font-family: var(--font); min-width: 0; 
}
input[type=search]:focus, select:focus { border-color: var(--accent); }
select option { background: var(--surface2); }
input[type=range] { accent-color: var(--accent); cursor: pointer; }

/* CASE GRID */
.cases-grid { 
  display: grid; 
  grid-template-columns: 1fr; 
  gap: 12px; 
}
@media (min-width: 500px) { .cases-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 900px) { .cases-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 1200px) { .cases-grid { grid-template-columns: repeat(4, 1fr); } }

.case-card { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: var(--radius); padding: 14px; cursor: pointer; 
  transition: all 0.2s; position: relative; overflow: hidden;
  user-select: none;
  -webkit-user-select: none;
}
.case-card::before { 
  content: ''; position: absolute; top: 0; left: 0; right: 0; 
  height: 3px; background: var(--accent); opacity: 0; transition: opacity 0.2s; 
}
.case-card:hover { 
  border-color: var(--accent); transform: translateY(-2px); 
  box-shadow: 0 8px 24px rgba(0,212,170,0.12); 
}
.case-card:hover::before { opacity: 1; }
.case-card:active { transform: scale(0.98); }
.case-card.failed { border-color: rgba(255,107,107,0.3); }
.case-card.failed::before { background: var(--danger); }
.case-card.failed:hover { border-color: var(--danger); box-shadow: 0 8px 24px rgba(255,107,107,0.12); }
.case-header { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; }
.case-num { 
  background: var(--surface3); color: var(--text-muted); border-radius: 4px; 
  padding: 2px 5px; font-size: 9px; font-weight: 700; flex-shrink: 0; 
}
.case-name { font-weight: 700; font-size: 12px; line-height: 1.3; flex: 1; }
.case-meta { 
  color: var(--text-muted); font-size: 10px; margin-bottom: 8px; 
  display: flex; align-items: center; gap: 6px; flex-wrap: wrap; 
}
.score-bar-wrap { margin-bottom: 8px; }
.score-row { display: flex; align-items: center; gap: 6px; margin-bottom: 2px; }
.score-label { 
  font-size: 8px; color: var(--text-muted); width: 55px; 
  flex-shrink: 0; font-weight: 600; text-transform: uppercase; 
}
.score-bar { flex: 1; height: 3px; background: var(--surface3); border-radius: 2px; overflow: hidden; }
.score-fill { height: 100%; border-radius: 2px; transition: width 0.4s; }
.score-num { font-size: 8px; color: var(--text-muted); width: 10px; text-align: right; flex-shrink: 0; }
.total-score { display: inline-flex; align-items: center; gap: 4px; font-size: 16px; font-weight: 900; margin-bottom: 6px; }
.total-score .denom { font-size: 10px; color: var(--text-muted); font-weight: 400; }
.tags-wrap { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 6px; }
.tag { 
  background: var(--surface3); color: var(--text-muted); border-radius: 3px; 
  padding: 2px 5px; font-size: 9px; font-weight: 500; 
}
.failed-badge { 
  background: rgba(255,107,107,0.15); color: var(--danger); 
  border-radius: 4px; padding: 2px 6px; font-size: 9px; font-weight: 700; 
}

/* OUTCOME BADGES */
.outcome-badge { 
  border-radius: 4px; padding: 2px 8px; font-size: 10px; 
  font-weight: 700; display: inline-flex; align-items: center; gap: 3px; 
}
.ob-0 { background: rgba(139,0,0,0.25); color: #ff4444; }
.ob-1 { background: rgba(231,76,60,0.2); color: #ff6b6b; }
.ob-2 { background: rgba(255,217,61,0.15); color: #ffd93d; }
.ob-3 { background: rgba(255,217,61,0.2); color: #ffe066; }
.ob-4 { background: rgba(0,184,148,0.2); color: #00b894; }
.ob-5 { background: rgba(0,212,170,0.2); color: var(--accent); }

/* MODAL */
.modal-overlay { 
  position: fixed; inset: 0; z-index: 200; 
  background: rgba(0,0,0,0.85); backdrop-filter: blur(6px); 
  display: none; align-items: flex-start; justify-content: center; 
  padding: 60px 16px 20px; overflow-y: auto;
  pointer-events: none;
  visibility: hidden;
}
.modal-overlay.open { 
  display: flex; 
  pointer-events: auto;
  visibility: visible;
}
.modal { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: 12px; padding: 20px; max-width: 800px; width: 100%; 
  position: relative; animation: slideUp 0.25s ease; 
}
@keyframes slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.modal-close { 
  position: absolute; top: 12px; right: 12px; 
  background: var(--surface2); border: none; color: var(--text-muted); 
  width: 44px; height: 44px; border-radius: 6px; cursor: pointer; 
  font-size: 18px; display: flex; align-items: center; justify-content: center; 
  transition: all 0.2s;
  z-index: 10;
}
.modal-close:hover { background: var(--surface3); color: var(--text); }
.modal-title { font-size: 18px; font-weight: 800; margin-bottom: 4px; padding-right: 36px; line-height: 1.3; }
.modal-meta { color: var(--text-muted); font-size: 11px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.modal-section { margin-bottom: 16px; }
.modal-section-title { 
  font-size: 10px; font-weight: 700; text-transform: uppercase; 
  letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 6px; 
}
.modal-section p { font-size: 12px; line-height: 1.7; color: #c8cad8; }
.benjamin-box { 
  background: linear-gradient(135deg, rgba(0,212,170,0.08), rgba(0,245,196,0.04)); 
  border: 1px solid rgba(0,212,170,0.25); border-radius: 8px; 
  padding: 12px 14px; margin-top: 14px; 
}
.benjamin-box .label { 
  font-size: 9px; font-weight: 800; text-transform: uppercase; 
  color: var(--accent); letter-spacing: 0.5px; margin-bottom: 4px; 
}
.benjamin-box p { font-size: 12px; line-height: 1.6; color: var(--text); }

/* TIMELINE */
.timeline-wrap { margin: 14px 0; }
.timeline-item { 
  display: flex; gap: 10px; padding: 8px 0; 
  border-bottom: 1px solid var(--border); 
}
.timeline-item:last-child { border-bottom: none; }
.timeline-year { 
  font-size: 11px; font-weight: 700; color: var(--text-muted); 
  width: 40px; flex-shrink: 0; 
}
.timeline-marker { 
  font-size: 9px; font-weight: 700; padding: 2px 6px; 
  border-radius: 3px; flex-shrink: 0; 
}
.tm-BUILDUP { background: rgba(107,115,148,0.2); color: #6b7394; }
.tm-TIP { background: rgba(255,217,61,0.2); color: #ffd93d; }
.tm-WIN { background: rgba(0,212,170,0.2); color: var(--accent); }
.tm-PARTIAL-WIN { background: rgba(0,206,201,0.2); color: #00cec9; }
.tm-SETBACK { background: rgba(253,150,68,0.2); color: #fd9644; }
.tm-REVERSAL { background: rgba(255,107,107,0.2); color: var(--danger); }
.tm-CONSOLIDATION { background: rgba(116,185,255,0.2); color: #74b9ff; }
.tm-MILESTONE { background: rgba(162,155,254,0.2); color: #a29bfe; }
.tm-ONGOING { background: rgba(0,207,232,0.2); color: #00cfe8; }
.tm-SUPPRESSED { background: rgba(192,57,43,0.2); color: #c0392b; }
.timeline-text { font-size: 11px; color: #c8cad8; line-height: 1.5; flex: 1; }

/* RADAR CHART */
.radar-wrap { width: 180px; height: 180px; margin: 0 auto; }

/* ACTORS SECTION */
.actors-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
@media (min-width: 600px) { .actors-grid { grid-template-columns: 1fr 1fr; } }
.actor-group { background: var(--surface2); border-radius: 8px; padding: 12px; }
.actor-group-title { 
  font-size: 10px; font-weight: 700; text-transform: uppercase; 
  color: var(--text-muted); margin-bottom: 6px; 
}
.actor-list { list-style: none; }
.actor-list li { 
  font-size: 11px; padding: 3px 0; 
  border-bottom: 1px solid rgba(37,42,58,0.5); 
}
.actor-list li:last-child { border-bottom: none; }

/* SOURCES */
.sources-list { list-style: none; }
.sources-list li { font-size: 11px; padding: 4px 0; line-height: 1.5; }
.sources-list a { 
  color: var(--accent); text-decoration: none; 
  word-break: break-all;
  overflow-wrap: break-word;
}
.sources-list a:hover { text-decoration: underline; }

/* FORECAST CALENDAR */
.calendar-wrap { 
  overflow-x: auto; 
  -webkit-overflow-scrolling: touch; 
  max-width: 100%;
  margin: 0 -16px;
  padding: 0 16px;
}
.calendar-track { 
  display: flex; gap: 12px; padding: 10px 0;
  width: max-content;
}
.calendar-year { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: var(--radius); padding: 14px; min-width: 300px; 
}
.calendar-year-title { 
  font-size: 20px; font-weight: 900; margin-bottom: 10px; 
  color: var(--accent); 
}
.calendar-event { 
  background: var(--surface2); border-radius: 6px; 
  padding: 12px; margin-bottom: 8px; cursor: pointer;
  transition: all 0.2s; border-left: 3px solid var(--accent);
  min-height: 44px;
  user-select: none;
  -webkit-user-select: none;
}
.calendar-event:hover { background: var(--surface3); }
.calendar-event:active { transform: scale(0.98); }
.calendar-event.hot { border-left-color: var(--danger); }
.calendar-event.warm { border-left-color: var(--warning); }
.calendar-event-date { font-size: 10px; color: var(--text-muted); font-weight: 600; }
.calendar-event-title { font-size: 12px; font-weight: 700; margin: 2px 0; }
.calendar-event-movements { font-size: 10px; color: var(--text-muted); }

/* CANDIDATE CARDS */
.candidate-card { 
  background: var(--surface); border: 1px solid var(--border); 
  border-radius: var(--radius); padding: 16px; margin-bottom: 12px;
  cursor: pointer; transition: all 0.2s;
}
.candidate-card:hover { border-color: var(--accent); }
.candidate-card:active { transform: scale(0.99); }
.candidate-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.candidate-name { font-size: 15px; font-weight: 800; margin-bottom: 2px; }
.candidate-score { font-size: 22px; font-weight: 900; }
.candidate-score.hot { color: var(--danger); }
.candidate-score.warm { color: var(--warning); }
.candidate-score.building { color: var(--accent); }
.candidate-body { color: var(--text-muted); font-size: 12px; line-height: 1.7; }
.candidate-body p { margin-bottom: 6px; }
.candidate-body strong { color: var(--text); }

/* ECOSYSTEM */
.eco-tabs { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
.eco-tab-btn { 
  background: var(--surface); border: 1px solid var(--border); 
  color: var(--text-muted); padding: 10px 16px; border-radius: 8px; 
  cursor: pointer; font-size: 12px; font-weight: 600; transition: all 0.2s;
  min-height: 44px;
}
.eco-tab-btn:hover { border-color: var(--accent); color: var(--text); }
.eco-tab-btn.active { background: rgba(0,212,170,0.1); border-color: var(--accent); color: var(--accent); }
.eco-tab-btn:active { transform: scale(0.95); }
.eco-tab-panel { display: none; }
.eco-tab-panel.active { display: block; }
.domain-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
@media (min-width: 700px) { .domain-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1100px) { .domain-grid { grid-template-columns: repeat(3, 1fr); } }
.domain-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 14px; max-width: 100%; overflow: hidden; }
.domain-name { font-size: 14px; font-weight: 800; color: var(--accent); margin-bottom: 8px; }
.domain-section-label { 
  font-size: 9px; font-weight: 700; text-transform: uppercase; 
  color: var(--text-muted); margin: 8px 0 4px; 
}
.org-item { padding: 8px 0; border-bottom: 1px solid rgba(37,42,58,0.5); min-height: 44px; display: flex; flex-direction: column; justify-content: center; }
.org-item:last-child { border-bottom: none; }
.org-name { font-weight: 700; font-size: 11px; }
.org-budget { color: var(--accent); font-size: 10px; font-weight: 600; }
.org-tactics { color: var(--text-muted); font-size: 10px; line-height: 1.4; margin-top: 2px; }
.funder-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin-bottom: 12px; cursor: pointer; transition: all 0.2s; }
.funder-card:hover { border-color: var(--accent); }
.funder-card:active { transform: scale(0.99); }
.funder-name { font-size: 14px; font-weight: 800; margin-bottom: 4px; }
.funder-giving { color: var(--success); font-size: 13px; font-weight: 700; margin-bottom: 4px; }
.funder-focus { color: var(--text-muted); font-size: 11px; line-height: 1.5; }
.funder-domains { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
.funder-domain { 
  background: rgba(0,212,170,0.1); color: var(--accent); 
  border-radius: 3px; padding: 2px 6px; font-size: 9px; font-weight: 500; 
}

/* SCROLLBAR */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* PAGINATION */
.pagination { display: flex; gap: 4px; margin-top: 16px; justify-content: center; flex-wrap: wrap; }
.page-btn { 
  background: var(--surface); border: 1px solid var(--border); 
  color: var(--text-muted); padding: 8px 12px; border-radius: 6px; 
  cursor: pointer; font-size: 11px; transition: all 0.15s; 
  min-width: 44px; min-height: 44px;
  display: inline-flex; align-items: center; justify-content: center;
}
.page-btn:hover { border-color: var(--accent); color: var(--text); }
.page-btn.active { background: var(--accent); border-color: var(--accent); color: #000; }
.page-btn:active { transform: scale(0.92); }
.results-count { color: var(--text-muted); font-size: 11px; margin-bottom: 10px; }

/* FOOTER */
.footer { 
  text-align: center; padding: 20px; color: var(--text-muted); 
  font-size: 11px; border-top: 1px solid var(--border); margin-top: 40px; 
}
.footer a { color: var(--accent); text-decoration: none; }
.footer a:hover { text-decoration: underline; }

/* METHODOLOGY */
.methodology-content { font-size: 12px; line-height: 1.8; color: #c8cad8; }
.methodology-content h3 { color: var(--text); font-size: 14px; margin: 16px 0 8px; }
.methodology-content p { margin-bottom: 10px; }
.methodology-content ul { padding-left: 18px; margin-bottom: 10px; }
.methodology-content li { margin-bottom: 4px; }
.methodology-content strong { color: var(--text); }
.condition-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0; }
@media (min-width: 600px) { .condition-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 900px) { .condition-grid { grid-template-columns: repeat(5, 1fr); } }
.condition-card { background: var(--surface2); border-radius: 8px; padding: 12px; text-align: center; }
.condition-card .num { font-size: 24px; font-weight: 900; color: var(--accent); }
.condition-card .name { font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">SIPM <span>Monitor</span></div>
  <button class="nav-tab active" data-tab="network">Network</button>
  <button class="nav-tab" data-tab="cases">Cases</button>
  <button class="nav-tab" data-tab="forecast">Forecast</button>
  <button class="nav-tab" data-tab="ecosystem">Ecosystem</button>
  <button class="nav-tab" data-tab="methodology">About</button>
  <div class="nav-right">
    <span class="last-updated">Updated: Mar 15, 2026</span>
    <span class="badge-count">100 Cases</span>
  </div>
</nav>

<div class="network-tooltip" id="network-tooltip"></div>

<!-- NETWORK VIEW -->
<div class="page active" id="page-network">
  <div class="stats-grid" id="stats-grid"></div>
  
  <div class="network-wrapper">
    <!-- Network Graph Container -->
    <div class="card" style="padding: 0; overflow: hidden; margin-bottom: 0; flex: 1;">
      <div id="network-container">
        <div class="network-filters" id="network-filters">
          <button class="network-filter-btn active" data-cat="All">All</button>
          <button class="network-filter-btn" data-cat="Climate">Climate</button>
          <button class="network-filter-btn" data-cat="Democracy">Democracy</button>
          <button class="network-filter-btn" data-cat="Labor">Labor</button>
          <button class="network-filter-btn" data-cat="Health">Health</button>
          <button class="network-filter-btn" data-cat="Digital">Digital</button>
          <button class="network-filter-btn" data-cat="Indigenous">Indigenous</button>
        </div>
        <svg id="network-svg" width="100%" height="100%"></svg>
        <div class="mobile-hint">👆 Tap bubbles for details</div>
      </div>
    </div>
    
    <!-- Interactive Legend Control Panel -->
    <div class="legend-panel" id="legend-panel">
      <div class="legend-panel-header" id="legend-header">
        <div class="legend-panel-title">
          <span>🎛️</span>
          <span>Filter & Explore</span>
        </div>
        <button class="legend-toggle-btn" id="legend-toggle">▼ Expand</button>
      </div>
      
      <div class="legend-panel-body" id="legend-body">
        <!-- Section 1: Node Size = SIPM Score -->
        <div class="legend-section">
          <div class="legend-section-title">Node Size = SIPM Score</div>
          <div class="node-size-scale">
            <div class="node-size-item" data-size="high">
              <div class="node-circle" style="width: 36px; height: 36px;"></div>
              <div class="node-label">High</div>
              <div class="node-range">20-25</div>
            </div>
            <div class="node-size-item" data-size="medium">
              <div class="node-circle" style="width: 26px; height: 26px;"></div>
              <div class="node-label">Med</div>
              <div class="node-range">14-19</div>
            </div>
            <div class="node-size-item" data-size="low">
              <div class="node-circle" style="width: 18px; height: 18px;"></div>
              <div class="node-label">Low</div>
              <div class="node-range">&lt;14</div>
            </div>
          </div>
        </div>
        
        <!-- Section 2: Node Color = Category -->
        <div class="legend-section">
          <div class="legend-section-title">Category</div>
          <div id="category-filters">
            <div class="legend-filter-item active" data-category="All">
              <div class="indicator" style="background: linear-gradient(135deg, var(--cat-climate), var(--cat-democracy), var(--cat-indigenous));"></div>
              <span class="label">All Categories</span>
              <span class="count" id="count-all">25</span>
            </div>
            <div class="legend-filter-item" data-category="Climate">
              <div class="indicator" style="background: var(--cat-climate);"></div>
              <span class="label">Climate</span>
              <span class="count" id="count-climate">8</span>
            </div>
            <div class="legend-filter-item" data-category="Democracy">
              <div class="indicator" style="background: var(--cat-democracy);"></div>
              <span class="label">Democracy</span>
              <span class="count" id="count-democracy">5</span>
            </div>
            <div class="legend-filter-item" data-category="Labor">
              <div class="indicator" style="background: var(--cat-labor);"></div>
              <span class="label">Labor</span>
              <span class="count" id="count-labor">3</span>
            </div>
            <div class="legend-filter-item" data-category="Health">
              <div class="indicator" style="background: var(--cat-health);"></div>
              <span class="label">Health</span>
              <span class="count" id="count-health">2</span>
            </div>
            <div class="legend-filter-item" data-category="Digital">
              <div class="indicator" style="background: var(--cat-digital);"></div>
              <span class="label">Digital</span>
              <span class="count" id="count-digital">2</span>
            </div>
            <div class="legend-filter-item" data-category="Indigenous">
              <div class="indicator" style="background: var(--cat-indigenous);"></div>
              <span class="label">Indigenous</span>
              <span class="count" id="count-indigenous">5</span>
            </div>
          </div>
        </div>
        
        <!-- Section 3: Edge Type Filter -->
        <div class="legend-section">
          <div class="legend-section-title">Connection Types</div>
          <div id="edge-filters">
            <div class="legend-filter-item active" data-edge="compound">
              <div class="checkbox"></div>
              <div class="indicator line dashed" style="background: var(--edge-compound);"></div>
              <span class="label">Compound Crisis</span>
              <span class="count" id="count-edge-compound">10</span>
            </div>
            <div class="legend-filter-item active" data-edge="actors">
              <div class="checkbox"></div>
              <div class="indicator line" style="background: var(--edge-actors);"></div>
              <span class="label">Shared Actors</span>
              <span class="count" id="count-edge-actors">6</span>
            </div>
            <div class="legend-filter-item active" data-edge="narrative">
              <div class="checkbox"></div>
              <div class="indicator line dotted" style="background: var(--edge-narrative);"></div>
              <span class="label">Narrative Dependency</span>
              <span class="count" id="count-edge-narrative">6</span>
            </div>
            <div class="legend-filter-item active" data-edge="geographic">
              <div class="checkbox"></div>
              <div class="indicator line" style="background: var(--edge-geographic);"></div>
              <span class="label">Geographic Overlap</span>
              <span class="count" id="count-edge-geographic">6</span>
            </div>
          </div>
        </div>
        
        <!-- Section 4: Trajectory Filter -->
        <div class="legend-section">
          <div class="legend-section-title">Trajectory</div>
          <div id="trajectory-filters">
            <div class="legend-filter-item" data-trajectory="tipping">
              <div class="indicator" style="background: var(--danger);"></div>
              <span class="label">🔴 Tipping Now</span>
              <span class="count" id="count-tipping">6</span>
            </div>
            <div class="legend-filter-item" data-trajectory="building">
              <div class="indicator" style="background: var(--warning);"></div>
              <span class="label">🟡 Building</span>
              <span class="count" id="count-building">12</span>
            </div>
            <div class="legend-filter-item" data-trajectory="early">
              <div class="indicator" style="background: var(--accent);"></div>
              <span class="label">🟢 Early Stage</span>
              <span class="count" id="count-early">7</span>
            </div>
          </div>
        </div>
        
        <!-- Section 5: Benjamin's Lens -->
        <div class="legend-section">
          <div class="legend-section-title">Special Views</div>
          <div class="benjamin-lens-toggle" id="benjamin-lens">
            <div class="toggle-switch"></div>
            <span class="toggle-label">Benjamin's Lens</span>
            <span class="toggle-icon">🎨</span>
          </div>
          <p style="font-size: 9px; color: var(--text-muted); margin-top: 6px; line-height: 1.4;">
            Highlights movements with specific visual intervention opportunities
          </p>
        </div>
        
        <button class="reset-filters-btn" id="reset-all-filters">↺ Reset All Filters</button>
      </div>
    </div>
  </div>

  <div class="two-col" style="margin-top: 14px;">
    <div class="card">
      <div class="card-title">SIPM Score Distribution</div>
      <div class="chart-wrap-sm" id="chart-scores"></div>
    </div>
    <div class="card">
      <div class="card-title">Outcome Distribution</div>
      <div class="chart-wrap-sm" id="chart-outcomes"></div>
    </div>
  </div>
</div>

<!-- CASES LIST -->
<div class="page" id="page-cases">
  <div class="filters">
    <input type="search" id="search-input" placeholder="Search cases..." style="flex: 1; min-width: 150px; max-width: 300px;">
    <select id="filter-region">
      <option value="">All Regions</option>
    </select>
    <select id="filter-outcome">
      <option value="">Any Outcome</option>
      <option value="5">5 – Full Change</option>
      <option value="4">4 – Major Win</option>
      <option value="3">3 – Cultural Shift</option>
      <option value="2">2 – Partial Win</option>
      <option value="1">1 – Awareness Only</option>
      <option value="0">0 – Suppressed</option>
    </select>
    <div style="display: flex; align-items: center; gap: 4px;">
      <span style="font-size: 10px; color: var(--text-muted);">Min SIPM:</span>
      <input type="range" id="filter-score" min="0" max="25" value="0" style="width: 60px;">
      <span id="score-val" style="font-size: 10px; color: var(--text-muted); width: 16px;">0</span>
    </div>
    <button class="filter-btn" id="reset-filters">↺</button>
  </div>
  <div class="filters" style="margin-bottom: 8px;">
    <span style="font-size: 10px; color: var(--text-muted);">Sort:</span>
    <button class="filter-btn active" data-sort="num">#</button>
    <button class="filter-btn" data-sort="score">SIPM ↓</button>
    <button class="filter-btn" data-sort="outcome">Outcome ↓</button>
    <button class="filter-btn" data-sort="year">Year</button>
  </div>
  <div class="results-count" id="results-count"></div>
  <div class="cases-grid" id="cases-grid"></div>
  <div class="pagination" id="pagination"></div>
</div>

<!-- FORECAST CALENDAR -->
<div class="page" id="page-forecast">
  <div class="card" style="background: linear-gradient(135deg, rgba(0,212,170,0.06), rgba(255,107,107,0.04));">
    <div class="card-title" style="color: var(--accent);">🔥 Active Inflection Windows — 2025-2028</div>
    <p style="color: var(--text-muted); font-size: 12px; margin-bottom: 14px;">
      Key global events that could catalyze movement tipping points. Scored using the SIPM 5-condition framework.
    </p>
  </div>
  
  <div class="calendar-wrap">
    <div class="calendar-track" id="calendar-track"></div>
  </div>
  
  <div class="card" style="margin-top: 20px;">
